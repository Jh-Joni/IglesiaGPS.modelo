<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Iglesia.MVC</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Iglesia.MVC.styles.css" asp-append-version="true" />
    <link rel="icon" type="image/png" href="~/imagen/logosinfondo.png" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark app-header shadow-sm">
            <div class="container-fluid">
                <a class="navbar-brand d-flex align-items-center" asp-area="" asp-controller="Home" asp-action="Index">
                    <img src="~/imagen/logosinfondo.png" alt="Logo Iglesia GPS" style="height: 35px; margin-right: 10px;" />
                    Iglesia GPS
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-end">
                    <ul class="navbar-nav ms-auto align-items-center">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">Inicio</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="SolicitudesDirector" asp-action="Index">Solicitud a Director</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Canciones" asp-action="Index">Canciones</a>
                        </li>
                        
                        @{ 
                            var usuario = Context.Session.GetString("UsuarioNombre"); 
                            var rol = Context.Session.GetString("UsuarioRol");
                            
                            var badgeClass = "bg-secondary"; // Por defecto (Usuario)
                            var badgeStyle = "";
                            
                            if (rol == "Director") 
                            {
                                badgeClass = "";
                                badgeStyle = "background: linear-gradient(135deg, #3C6852, #2B4A3B, #1A2D24); color: white;";
                            }
                            else if (rol == "Desarrollador") 
                            {
                                badgeClass = "";
                                badgeStyle = "background: linear-gradient(135deg, #08402A, #0D6845, #53947C, #099A65); color: white;";
                            }
                        }
                        @if (!string.IsNullOrEmpty(usuario))
                        {
                            <li class="nav-item d-flex align-items-center me-2">
                                <span class="badge @badgeClass px-3 py-2 rounded-pill shadow-sm d-flex align-items-center border border-white border-opacity-25" style="font-size: 0.95rem; @badgeStyle">
                                    <i class="bi bi-person-circle me-2 fs-6"></i> @usuario
                                </span>
                            </li>
                            @if (rol == "Desarrollador")
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-warning fw-bold" asp-area="" asp-controller="Usuarios" asp-action="Gestion">
                                        <i class="bi bi-shield-lock"></i> Gestión Usuarios
                                    </a>
                                </li>
                            }
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-controller="Auth" asp-action="CerrarSesion">Cerrar sesión</a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-controller="Auth" asp-action="Login">Iniciar sesión</a>
                            </li>
                        }
                        
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Privacy">Acerca</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
        <main role="main">
            @RenderBody()
        </main>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - Iglesia.MVC - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
