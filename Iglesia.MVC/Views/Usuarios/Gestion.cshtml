@model IEnumerable<IglesiaGPS.modelo.Usuario>

@{
    ViewData["Title"] = "Gestión de Usuarios";
    
    // Agrupar usuarios por rol de forma segura comprobando que Rol no sea null
    var usuariosDefault = Model.Where(u => u.Rol != null && u.Rol.Nombre == "Usuario").ToList();
    var directores = Model.Where(u => u.Rol != null && u.Rol.Nombre == "Director").ToList();
    var desarrolladores = Model.Where(u => u.Rol != null && u.Rol.Nombre == "Desarrollador").ToList();
    
    // Contar usuarios sin rol o con roles no estándar por precaución (opcional)
    var otros = Model.Where(u => u.Rol == null || (u.Rol.Nombre != "Usuario" && u.Rol.Nombre != "Director" && u.Rol.Nombre != "Desarrollador")).ToList();
    usuariosDefault.AddRange(otros); // Por defecto tratar a los "otros" como usuarios base
}

<div class="container gestion-container mt-4 mb-5">
    <div class="gestion-header mb-5 text-center position-relative">
        <h1 class="display-5 fw-bold mb-2" style="color: #ffffff; text-shadow: 0 0 15px rgba(0, 229, 255, 0.6); letter-spacing: -1px;">
            <i class="bi bi-people-fill me-2" style="color: #00e5ff;"></i>Gestión de Usuarios
        </h1>
        <p style="color: #94a3b8; font-size: 1.1rem;">Administra los roles del sistema: promueve o degrada usuarios según sea necesario.</p>
    </div>

    @if (TempData["MensajeGestion"] != null)
    {
        <div class="alert neo-alert-success alert-dismissible fade show shadow-sm" role="alert">
            <i class="bi bi-check-circle-fill me-2" style="color: #1de9b6;"></i> @TempData["MensajeGestion"]
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["ErrorGestion"] != null)
    {
        <div class="alert neo-alert-danger alert-dismissible fade show shadow-sm" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2" style="color: #ff3d00;"></i> @TempData["ErrorGestion"]
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row g-4">
        
        <!-- COLUMNA USUARIOS -->
        <div class="col-md-4">
            <div class="rol-columna col-usuarios neo-panel">
                <div class="columna-titulo d-flex align-items-center justify-content-center gap-3">
                    <i class="bi bi-person fs-4"></i> Usuarios Base
                    
                    <!-- Cyber Ring Widget -->
                    <div class="cyber-ring-sm">
                        <svg width="40" height="40" viewBox="0 0 40 40">
                            <circle cx="20" cy="20" r="16" class="ring-bg"></circle>
                            <circle cx="20" cy="20" r="16" class="ring-progress ring-usuarios" id="ringUsuarios" data-count="@usuariosDefault.Count"></circle>
                        </svg>
                        <div class="ring-text-sm" id="countUsuarios">@usuariosDefault.Count</div>
                    </div>
                </div>
                
                <div class="card-list-container">
                    @if(!usuariosDefault.Any())
                    {
                        <div class="text-center text-muted small py-4 empty-msg">No hay usuarios base en este momento.</div>
                    }
                    
                    @foreach (var u in usuariosDefault)
                    {
                        <div class="user-card neo-card-usuarios">
                            <div class="user-info">
                                <h5>@u.Nombre @u.Apellido</h5>
                                <p>@u.Correo</p>
                            </div>
                            <form method="post" asp-action="CambiarRol" asp-controller="Usuarios">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="usuarioId" value="@u.UsuarioId" />
                                <input type="hidden" name="nuevoRol" value="Director" />
                                <button type="submit" class="btn btn-accion btn-promover">
                                    <i class="bi bi-arrow-up-circle"></i> Subir a Director
                                </button>
                            </form>
                            <!-- BOTÓN DE ELIMINAR USUARIO -->
                            <form method="post" asp-action="DeleteConfirmed" asp-controller="Usuarios" class="mt-2" onsubmit="return confirm('¿Estás seguro de que deseas eliminar a este Usuario permanentemente?');">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@u.UsuarioId" />
                                <button type="submit" class="btn btn-accion" style="background: rgba(239, 68, 68, 0.1); border-color: #ef4444; color: #ef4444;">
                                    <i class="bi bi-trash"></i> Eliminar Usuario
                                </button>
                            </form>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- COLUMNA DIRECTORES -->
        <div class="col-md-4">
            <div class="rol-columna col-directores neo-panel">
                <div class="columna-titulo d-flex align-items-center justify-content-center gap-3">
                    <i class="bi bi-music-note-list fs-4"></i> Directores
                    
                    <!-- Cyber Ring Widget -->
                    <div class="cyber-ring-sm">
                        <svg width="40" height="40" viewBox="0 0 40 40">
                            <circle cx="20" cy="20" r="16" class="ring-bg"></circle>
                            <circle cx="20" cy="20" r="16" class="ring-progress ring-directores" id="ringDirectores" data-count="@directores.Count"></circle>
                        </svg>
                        <div class="ring-text-sm" id="countDirectores">@directores.Count</div>
                    </div>
                </div>

                <div class="card-list-container">
                    @if(!directores.Any())
                    {
                        <div class="text-center text-muted small py-4 empty-msg">No hay directores registrados.</div>
                    }

                    @foreach (var u in directores)
                    {
                        <div class="user-card neo-card-directores">
                            <div class="user-info">
                                <h5>@u.Nombre @u.Apellido</h5>
                                <p>@u.Correo</p>
                            </div>
                            <form method="post" asp-action="CambiarRol" asp-controller="Usuarios">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="usuarioId" value="@u.UsuarioId" />
                                <input type="hidden" name="nuevoRol" value="Usuario" />
                                <button type="submit" class="btn btn-accion btn-degradar">
                                    <i class="bi bi-arrow-down-circle"></i> Degradar a Usuario
                                </button>
                            </form>
                            <form method="post" asp-action="CambiarRol" asp-controller="Usuarios" class="mt-2">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="usuarioId" value="@u.UsuarioId" />
                                <input type="hidden" name="nuevoRol" value="Desarrollador" />
                                <button type="submit" class="btn btn-accion btn-dorado">
                                    <i class="bi bi-star"></i> Promover a Desarrollador
                                </button>
                            </form>
                            <!-- BOTÓN DE ELIMINAR USUARIO -->
                            <form method="post" asp-action="DeleteConfirmed" asp-controller="Usuarios" class="mt-2" onsubmit="return confirm('¿Estás seguro de que deseas eliminar a este Director permanentemente?');">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@u.UsuarioId" />
                                <button type="submit" class="btn btn-accion" style="background: rgba(239, 68, 68, 0.1); border-color: #ef4444; color: #ef4444;">
                                    <i class="bi bi-trash"></i> Eliminar Usuario
                                </button>
                            </form>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- COLUMNA DESARROLLADORES -->
        <div class="col-md-4">
            <div class="rol-columna col-desarrolladores neo-panel">
                <div class="columna-titulo d-flex align-items-center justify-content-center gap-3">
                    <i class="bi bi-code-slash fs-4"></i> Desarrolladores
                    
                    <!-- Cyber Ring Widget -->
                    <div class="cyber-ring-sm">
                        <svg width="40" height="40" viewBox="0 0 40 40">
                            <circle cx="20" cy="20" r="16" class="ring-bg"></circle>
                            <circle cx="20" cy="20" r="16" class="ring-progress ring-desarrolladores" id="ringDesarrolladores" data-count="@desarrolladores.Count"></circle>
                        </svg>
                        <div class="ring-text-sm" id="countDesarrolladores">@desarrolladores.Count</div>
                    </div>
                </div>

                <div class="card-list-container">
                    @if(!desarrolladores.Any())
                    {
                        <div class="text-center text-muted small py-4 empty-msg">No hay desarrolladores (crítico).</div>
                    }

                    @foreach (var u in desarrolladores)
                    {
                        <div class="user-card neo-card-desarrolladores">
                            <div class="user-info">
                                <h5>@u.Nombre @u.Apellido</h5>
                                <p>@u.Correo</p>
                            </div>
                            
                            @* Evitar que el desarrollador logueado se degrade por error *@
                            @if(Context.Session.GetString("UsuarioId") == u.UsuarioId.ToString())
                            {
                                <div class="text-center mt-3">
                                    <span class="badge" style="background: rgba(255, 61, 0, 0.2); color: var(--cyber-orange); border: 1px solid var(--cyber-orange);">
                                        <i class="bi bi-person-badge"></i> Tú (Sesión Actual)
                                    </span>
                                </div>
                            }
                            else
                            {
                                <div class="d-flex gap-2">
                                    <form method="post" asp-action="CambiarRol" asp-controller="Usuarios" class="flex-grow-1">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="usuarioId" value="@u.UsuarioId" />
                                        <input type="hidden" name="nuevoRol" value="Director" />
                                        <button type="submit" class="btn btn-accion btn-promover" style="margin-top: 0.8rem;">
                                            <i class="bi bi-arrow-down"></i> Director
                                        </button>
                                    </form>
                                    <form method="post" asp-action="CambiarRol" asp-controller="Usuarios" class="flex-grow-1">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="usuarioId" value="@u.UsuarioId" />
                                        <input type="hidden" name="nuevoRol" value="Usuario" />
                                        <button type="submit" class="btn btn-accion btn-degradar">
                                            <i class="bi bi-arrow-down-double"></i> Usuario
                                        </button>
                                    </form>
                                    <!-- BOTÓN DE ELIMINAR USUARIO -->
                                    <form method="post" asp-action="DeleteConfirmed" asp-controller="Usuarios" class="flex-grow-1" onsubmit="return confirm('¿Estás seguro de que deseas eliminar permanentemente a este Desarrollador?');">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@u.UsuarioId" />
                                        <button type="submit" class="btn btn-accion" style="background: rgba(239, 68, 68, 0.1); border-color: #ef4444; color: #ef4444;">
                                            <i class="bi bi-trash" style="font-size: 0.8rem;"></i>
                                        </button>
                                    </form>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>

    </div>
</div>

@section Styles {
    <style>
        :root {
            --cyber-bg: #0a0b10;
            --cyber-panel: #12141d;
            --cyber-box: #1a1e2b;
            --cyber-cyan: #00e5ff;
            --cyber-orange: #ff3d00;
            --cyber-teal: #1de9b6;
            --cyber-purple: #b388ff;
            --ring-circumference-sm: 100.53; /* 2 * pi * 16 */
        }
        
        body { 
            background-color: var(--cyber-bg) !important; 
            font-family: 'Inter', sans-serif;
            color: #fff;
        }

        .neo-alert-success {
            background: rgba(29, 233, 182, 0.1);
            border: 1px solid var(--cyber-teal);
            color: #fff;
        }

        .neo-alert-danger {
            background: rgba(255, 61, 0, 0.1);
            border: 1px solid rgba(255, 61, 0, 0.5);
            border-left: 4px solid var(--cyber-orange);
            color: #ffffff;
        }

        /* Paneles de Columnas */
        .neo-panel {
            background: var(--cyber-panel);
            border-radius: 15px;
            padding: 1.5rem;
            height: 100%;
            border: 1px solid rgba(255, 255, 255, 0.05);
            box-shadow: inset 0 0 20px rgba(0,0,0,0.5);
        }

        .columna-titulo {
            padding-bottom: 1rem;
            border-bottom: 1px solid rgba(255,255,255,0.1);
            margin-bottom: 1.5rem;
            font-weight: 700;
        }

        .col-usuarios .columna-titulo { color: #a9b7c6; text-shadow: 0 0 8px rgba(169, 183, 198, 0.4); }
        .col-directores .columna-titulo { color: var(--cyber-cyan); text-shadow: 0 0 8px var(--cyber-cyan); }
        .col-desarrolladores .columna-titulo { color: var(--cyber-orange); text-shadow: 0 0 8px var(--cyber-orange); }

        /* Tarjetas de Usuario */
        .user-card {
            background: var(--cyber-box);
            border-radius: 10px;
            padding: 1rem;
            margin-bottom: 1rem;
            transition: transform 0.3s ease, box-shadow 0.3s ease, opacity 0.5s ease;
            position: relative;
            overflow: hidden;
            border-left: 3px solid transparent;
        }
        
        .user-card:hover {
            transform: translateY(-3px) scale(1.02);
            z-index: 2;
        }

        .neo-card-usuarios { border-left-color: #6c757d; }
        .neo-card-usuarios:hover { box-shadow: 0 5px 15px rgba(108, 117, 125, 0.3); }

        .neo-card-directores { border-left-color: var(--cyber-cyan); }
        .neo-card-directores:hover { box-shadow: 0 5px 15px rgba(0, 229, 255, 0.3); }

        .neo-card-desarrolladores { border-left-color: var(--cyber-orange); }
        .neo-card-desarrolladores:hover { box-shadow: 0 5px 15px rgba(255, 61, 0, 0.3); }

        .user-info h5 {
            margin: 0 0 0.25rem 0;
            font-size: 1.1rem;
            font-weight: 600;
            color: #ffffff;
        }
        .user-info p {
            margin: 0;
            font-size: 0.85rem;
            color: #94a3b8;
        }

        /* Botones Acción Neon */
        .btn-accion {
            font-size: 0.8rem;
            padding: 0.4rem 0.6rem;
            border-radius: 6px;
            font-weight: 600;
            width: 100%;
            margin-top: 0.8rem;
            transition: all 0.3s ease;
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.1);
            color: #fff;
        }

        .btn-promover:hover {
            background: rgba(0, 229, 255, 0.15);
            border-color: var(--cyber-cyan);
            color: var(--cyber-cyan);
            box-shadow: 0 0 10px rgba(0, 229, 255, 0.3);
        }

        .btn-degradar:hover {
            background: rgba(255, 61, 0, 0.15);
            border-color: var(--cyber-orange);
            color: var(--cyber-orange);
            box-shadow: 0 0 10px rgba(255, 61, 0, 0.3);
        }
        
        .btn-dorado:hover {
            background: rgba(179, 136, 255, 0.15);
            border-color: var(--cyber-purple);
            color: var(--cyber-purple);
            box-shadow: 0 0 10px rgba(179, 136, 255, 0.3);
        }

        /* Cyber Ring Animation CSS */
        .cyber-ring-sm {
            position: relative;
            width: 40px; height: 40px;
            display: inline-flex; align-items: center; justify-content: center;
        }
        .cyber-ring-sm svg {
            transform: rotate(-90deg);
            position: absolute; top:0; left:0; width:100%; height:100%;
        }
        .ring-bg {
            fill: none; stroke: rgba(255,255,255,0.1); stroke-width: 4;
        }
        .ring-progress {
            fill: none; stroke-width: 4; stroke-linecap: round;
            stroke-dasharray: var(--ring-circumference-sm);
            stroke-dashoffset: var(--ring-circumference-sm);
            transition: stroke-dashoffset 1s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .ring-usuarios { stroke: #a9b7c6; filter: drop-shadow(0 0 3px rgba(169, 183, 198, 0.8)); }
        .ring-directores { stroke: var(--cyber-cyan); filter: drop-shadow(0 0 3px var(--cyber-cyan)); }
        .ring-desarrolladores { stroke: var(--cyber-orange); filter: drop-shadow(0 0 3px var(--cyber-orange)); }
        
        .ring-text-sm {
            position: relative; z-index: 2;
            font-size: 0.9rem; font-weight: bold; color: #fff;
        }
        
        /* Animación inicial en cascada para las tarjetas */
        .card-list-container > .user-card {
            animation: slideInUp 0.6s ease-out backwards;
        }
        @@keyframes slideInUp {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }
        /* Hacer delay escalonado asumiendo un máximo de 10 por columna */
        .card-list-container > .user-card:nth-child(1) { animation-delay: 0.1s; }
        .card-list-container > .user-card:nth-child(2) { animation-delay: 0.2s; }
        .card-list-container > .user-card:nth-child(3) { animation-delay: 0.3s; }
        .card-list-container > .user-card:nth-child(4) { animation-delay: 0.4s; }
        .card-list-container > .user-card:nth-child(5) { animation-delay: 0.5s; }
    </style>
}

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // Animacion inicial de los SVG Rings
            setTimeout(actualizarContadoresAnimados, 100);

            // AJAX submit logic
            const container = document.querySelector('.gestion-container');
            
            container.addEventListener('submit', function (e) {
                const form = e.target.closest('form');
                
                // Si es acción de ELIMINAR en Gestion de Usuarios (Usaremos AJAX también para evitar recargas completas)
                if (form && form.hasAttribute('action') && form.getAttribute('action').includes('DeleteConfirmed')) {
                    e.preventDefault();
                    if (!confirm("¿Segurísimo de querer eliminar al usuario de forma definitiva? Esta acción no se puede deshacer.")) return;

                    const actionUrl = form.getAttribute('action').replace('DeleteConfirmed', 'DeleteAjax');
                    const formData = new FormData(form);
                    const button = form.querySelector('button[type="submit"]');
                    const originalContent = button.innerHTML;
                    
                    button.disabled = true;
                    button.innerHTML = '<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>';

                    fetch(actionUrl, {
                        method: 'POST',
                        body: formData,
                        headers: { 'X-Requested-With': 'XMLHttpRequest' }
                    })
                    .then(response => response.json())
                    .then(data => {
                        if (data.success) {
                            const card = form.closest('.user-card');
                            // Animar salida
                            card.style.transition = 'opacity 0.4s ease, transform 0.4s ease';
                            card.style.opacity = '0';
                            card.style.transform = 'scale(0.8)';
                            setTimeout(() => {
                                card.remove();
                                actualizarContadoresAnimados();
                            }, 400);
                            mostrarAlerta('success', data.message);
                        } else {
                            mostrarAlerta('danger', data.message || 'Error al eliminar usuario.');
                            button.disabled = false;
                            button.innerHTML = originalContent;
                        }
                    })
                    .catch(err => {
                        console.error('Error:', err);
                        mostrarAlerta('danger', 'Error de conexión con el servidor.');
                        button.disabled = false;
                        button.innerHTML = originalContent;
                    });
                    return;
                }
                
                // Si es accion de CAMBIAR ROL
                if (!form || !form.hasAttribute('action') || !form.getAttribute('action').includes('CambiarRol')) return;

                e.preventDefault();

                const actionUrl = form.getAttribute('action').replace('CambiarRol', 'CambiarRolAjax');
                const formData = new FormData(form);
                const button = form.querySelector('button[type="submit"]');
                const originalContent = button.innerHTML;
                
                button.disabled = true;
                button.innerHTML = '<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span> ...';

                fetch(actionUrl, {
                    method: 'POST',
                    body: formData,
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        const nuevoRol = formData.get('nuevoRol');
                        const card = form.closest('.user-card');
                        const userId = form.querySelector('input[name="usuarioId"]').value;
                        
                        moverTarjeta(card, data.usuario, nuevoRol, userId);
                        mostrarAlerta('success', data.message);
                    } else {
                        mostrarAlerta('danger', data.message || 'Error al cambiar el rol.');
                        button.disabled = false;
                        button.innerHTML = originalContent;
                    }
                })
                .catch(err => {
                    console.error('Error:', err);
                    mostrarAlerta('danger', 'Error de conexión con el servidor.');
                    button.disabled = false;
                    button.innerHTML = originalContent;
                });
            });

            function moverTarjeta(card, usuario, nuevoRol, userId) {
                let columnaDestino, claseBorde, botonesHtml;
                const tokenInput = document.querySelector('input[name="__RequestVerificationToken"]').outerHTML;
                const sessionId = '@Context.Session.GetString("UsuarioId")';

                if (nuevoRol === 'Usuario') {
                    columnaDestino = document.querySelector('.col-usuarios .card-list-container');
                    claseBorde = "neo-card-usuarios";
                    botonesHtml = `
                        <form method="post" action="/Usuarios/CambiarRol">
                            ${tokenInput}
                            <input type="hidden" name="usuarioId" value="${userId}" />
                            <input type="hidden" name="nuevoRol" value="Director" />
                            <button type="submit" class="btn btn-accion btn-promover">
                                <i class="bi bi-arrow-up-circle"></i> Subir a Director
                            </button>
                        </form>`;
                } else if (nuevoRol === 'Director') {
                    columnaDestino = document.querySelector('.col-directores .card-list-container');
                    claseBorde = "neo-card-directores";
                    botonesHtml = `
                        <form method="post" action="/Usuarios/CambiarRol">
                            ${tokenInput}
                            <input type="hidden" name="usuarioId" value="${userId}" />
                            <input type="hidden" name="nuevoRol" value="Usuario" />
                            <button type="submit" class="btn btn-accion btn-degradar">
                                <i class="bi bi-arrow-down-circle"></i> Degradar a Usuario
                            </button>
                        </form>
                        <form method="post" action="/Usuarios/CambiarRol" class="mt-2">
                            ${tokenInput}
                            <input type="hidden" name="usuarioId" value="${userId}" />
                            <input type="hidden" name="nuevoRol" value="Desarrollador" />
                            <button type="submit" class="btn btn-accion btn-dorado">
                                <i class="bi bi-star"></i> Promover a Desarrollador
                            </button>
                        </form>`;
                } else if (nuevoRol === 'Desarrollador') {
                    columnaDestino = document.querySelector('.col-desarrolladores .card-list-container');
                    claseBorde = "neo-card-desarrolladores";
                    if (userId === sessionId) {
                         botonesHtml = `<div class="text-center mt-3"><span class="badge" style="background: rgba(255, 61, 0, 0.2); color: var(--cyber-orange); border: 1px solid var(--cyber-orange);"><i class="bi bi-person-badge"></i> Tú (Sesión Actual)</span></div>`;
                    } else {
                        botonesHtml = `
                            <div class="d-flex gap-2">
                                <form method="post" action="/Usuarios/CambiarRol" class="flex-grow-1">
                                    ${tokenInput}
                                    <input type="hidden" name="usuarioId" value="${userId}" />
                                    <input type="hidden" name="nuevoRol" value="Director" />
                                    <button type="submit" class="btn btn-accion btn-promover" style="margin-top: 0.8rem;">
                                        <i class="bi bi-arrow-down"></i> Director
                                    </button>
                                </form>
                                <form method="post" action="/Usuarios/CambiarRol" class="flex-grow-1">
                                    ${tokenInput}
                                    <input type="hidden" name="usuarioId" value="${userId}" />
                                    <input type="hidden" name="nuevoRol" value="Usuario" />
                                    <button type="submit" class="btn btn-accion btn-degradar" style="margin-top: 0.8rem;">
                                        <i class="bi bi-arrow-down-double"></i> Usuario
                                    </button>
                                </form>
                            </div>`;
                    }
                }

                // Animate Out
                card.style.opacity = '0';
                card.style.transform = 'scale(0.8)';

                setTimeout(() => {
                    // Actualizar contenido y clase
                    card.className = "user-card " + claseBorde;
                    card.style.animation = "none"; // remove intro anim
                    card.innerHTML = `
                        <div class="user-info">
                            <h5>${usuario.nombre} ${usuario.apellido}</h5>
                            <p>${usuario.correo}</p>
                        </div>
                        ${botonesHtml}
                    `;
                    
                    const vacio = columnaDestino.querySelector('.empty-msg');
                    if (vacio) vacio.remove();

                    columnaDestino.insertBefore(card, columnaDestino.firstChild);

                    // Animate In
                    void card.offsetWidth;
                    card.style.opacity = '1';
                    card.style.transform = 'scale(1)';

                    actualizarContadoresAnimados();

                }, 400); // Wait for fade out
            }

            function actualizarContadoresAnimados() {
                const circ = 100.53; 

                const cols = [
                    { id: 'ringUsuarios', txt: 'countUsuarios', classSelector: '.col-usuarios' },
                    { id: 'ringDirectores', txt: 'countDirectores', classSelector: '.col-directores' },
                    { id: 'ringDesarrolladores', txt: 'countDesarrolladores', classSelector: '.col-desarrolladores' }
                ];

                // Calculamos total actual para escalado relativo o fijo
                let totalActual = 0;
                cols.forEach(c => totalActual += document.querySelector(c.classSelector).querySelectorAll('.user-card').length);
                let divisor = Math.max(10, totalActual); // que al menos la escala sea respecto a 10

                cols.forEach(c => {
                    const count = document.querySelector(c.classSelector).querySelectorAll('.user-card').length;
                    document.getElementById(c.txt).textContent = count;
                    const ring = document.getElementById(c.id);
                    
                    let offset = circ - (count / divisor) * circ;
                    // Asegurar que no baja del maxoffset (círculo lleno)
                    if(offset < 0) offset = 0;
                    ring.style.strokeDashoffset = offset;
                });
            }

            function mostrarAlerta(tipo, mensaje) {
                document.querySelectorAll('.alert').forEach(a => a.remove());
                const div = document.createElement('div');
                div.className = `alert neo-alert-${tipo} alert-dismissible fade show shadow-sm`;
                div.role = 'alert';
                const icon = tipo === 'success' ? 'bi-check-circle-fill' : 'bi-exclamation-triangle-fill';
                const colorV = tipo === 'success' ? '#1de9b6' : '#ff3d00';
                div.innerHTML = `<i class="bi ${icon} me-2" style="color: ${colorV};"></i> ${mensaje}
                                 <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>`;

                const header = document.querySelector('.gestion-header');
                header.insertAdjacentElement('afterend', div);
                
                setTimeout(() => {
                    const alertNode = new bootstrap.Alert(div);
                    alertNode.close();
                }, 4000);
            }
        });
    </script>
}
