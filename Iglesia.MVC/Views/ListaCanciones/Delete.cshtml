@model IglesiaGPS.modelo.ListaCanciones

@{
    ViewData["Title"] = "Eliminar Repertorio";
}

<div class="row justify-content-center mt-5">
    <div class="col-lg-6 col-md-8">
        <div class="card shadow-lg border-0 rounded-4" style="background: rgba(255,255,255,0.9); backdrop-filter: blur(8px);">
            <div class="card-body p-5 text-center">
                
                <div class="mb-4 text-danger">
                    <i class="bi bi-trash-circle display-1"></i>
                </div>
                
                <h2 class="fw-bold text-dark mb-3">Eliminar Repertorio</h2>
                
                <p class="text-muted fs-5 mb-4">
                    ¿Estás seguro que deseas eliminar el repertorio musical <strong>@Model.Titulo</strong>? Esta acción no se puede deshacer.
                </p>

                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger shadow-sm rounded-3 text-start">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i> @ViewBag.Error
                    </div>
                }

                <div class="bg-light p-4 rounded-3 text-start mb-4 shadow-sm border">
                    <div class="row mb-2">
                        <div class="col-sm-4 text-muted fw-bold">ID:</div>
                        <div class="col-sm-8 text-dark">@Model.ListaCancionesId</div>
                    </div>
                    <div class="row mb-2">
                        <div class="col-sm-4 text-muted fw-bold">Creado en:</div>
                        <div class="col-sm-8 text-dark">@Model.FechaCreacion.ToString("dd MMMM yyyy HH:mm")</div>
                    </div>
                    <div class="row">
                        <div class="col-sm-4 text-muted fw-bold">Estado:</div>
                        <div class="col-sm-8 text-dark">@(Model.Publicada ? "Pública" : "Privada")</div>
                    </div>
                </div>

                <form asp-action="Delete" method="post" class="d-flex justify-content-center gap-3">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="ListaCancionesId" />
                    
                    <a asp-action="Index" class="btn btn-light btn-lg rounded-pill px-4 fw-bold shadow-sm">
                        <i class="bi bi-arrow-left me-2"></i>Cancelar
                    </a>
                    
                    <button type="submit" class="btn btn-danger btn-lg rounded-pill px-5 fw-bold shadow-sm">
                        <i class="bi bi-trash3 me-2"></i>¡Sí, Eliminar!
                    </button>
                </form>

            </div>
        </div>
    </div>
</div>
