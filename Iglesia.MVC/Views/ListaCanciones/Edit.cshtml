@model IglesiaGPS.modelo.ListaCanciones

@{
    ViewData["Title"] = "Editar Repertorio";
    var cancionesDisponibles = ViewBag.CancionesDisponibles as List<IglesiaGPS.modelo.Cancion> ?? new List<IglesiaGPS.modelo.Cancion>();
    var seleccionadas = ViewBag.Seleccionadas as List<int> ?? new List<int>();
}

<div class="row justify-content-center mt-4">
    <div class="col-lg-10">
        <div class="card shadow-lg border-0 rounded-4 bg-white" style="background: rgba(255,255,255,0.8) !important; backdrop-filter: blur(10px);">
            <div class="card-header bg-transparent border-0 pt-4 pb-0 text-center">
                <h2 class="fw-bold mb-0">✏️ Editar Repertorio</h2>
                <p class="text-muted mt-2">Modifica la selección (debe haber entre <strong>5 y 7 canciones</strong>).</p>
            </div>
            <div class="card-body p-4 p-md-5">

                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger shadow-sm rounded-3">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i> @ViewBag.Error
                    </div>
                }

                <form asp-action="Edit" method="post" id="formRepertorio">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="ListaCancionesId" />

                    <div class="mb-4">
                        <label asp-for="Titulo" class="form-label fw-bold">Título del Repertorio</label>
                        <input asp-for="Titulo" class="form-control form-control-lg rounded-3 shadow-sm bg-light border-0" required />
                        <span asp-validation-for="Titulo" class="text-danger"></span>
                    </div>

                    <div class="mb-4 d-flex justify-content-between align-items-center">
                        <label class="form-label fw-bold mb-0">Canciones Disponibles</label>
                        <span class="badge bg-primary rounded-pill px-3 py-2 fs-6" id="contadorSeleccion">0 / 7 Seleccionadas</span>
                    </div>

                    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-3 mb-4" id="gridCanciones">
                        @foreach (var cancion in cancionesDisponibles)
                        {
                            bool isChecked = seleccionadas.Contains(cancion.CancionId);
                            <div class="col">
                                <label class="w-100 h-100">
                                    <input type="checkbox" name="cancionesSeleccionadas" value="@cancion.CancionId" class="d-none cancion-checkbox" @(isChecked ? "checked" : "") />
                                    <div class="card h-100 border-2 rounded-3 cursor-pointer cancion-selector transition-hover shadow-sm" style="transition: all 0.3s; cursor: pointer;">
                                        <div class="card-body text-center p-3">
                                            @if (!string.IsNullOrEmpty(cancion.FotoUrl))
                                            {
                                                <img src="@cancion.FotoUrl" class="rounded-circle mx-auto mb-2 object-fit-cover shadow-sm" style="width: 50px; height: 50px;" alt="Foto">
                                            }
                                            else
                                            {
                                                <div class="bg-light text-secondary rounded-circle mx-auto mb-2 d-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
                                                    <i class="bi bi-music-note fs-3"></i>
                                                </div>
                                            }
                                            <h6 class="fw-bold text-truncate mb-1">@cancion.Titulo</h6>
                                            <small class="text-muted d-block text-truncate">@cancion.Autor</small>
                                        </div>
                                    </div>
                                </label>
                            </div>
                        }
                    </div>

                    <div class="d-flex justify-content-between pt-3 border-top mt-5">
                        <a asp-action="Index" class="btn btn-light rounded-pill px-4 fw-bold">Cancelar</a>
                        <button type="submit" class="btn btn-primary rounded-pill px-5 fw-bold shadow-sm" id="btnGuardar">Guardar Cambios</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const checkboxes = document.querySelectorAll('.cancion-checkbox');
            const contador = document.getElementById('contadorSeleccion');
            const btnGuardar = document.getElementById('btnGuardar');
            const form = document.getElementById('formRepertorio');

            function actualizarEstado() {
                let s = document.querySelectorAll('.cancion-checkbox:checked').length;
                contador.textContent = s + " / 7 Seleccionadas";
                
                if (s >= 5 && s <= 7) {
                    contador.className = "badge bg-success rounded-pill px-3 py-2 fs-6 shadow-sm";
                } else {
                    contador.className = "badge bg-warning text-dark rounded-pill px-3 py-2 fs-6 shadow-sm";
                }

                checkboxes.forEach(cb => {
                    const card = cb.nextElementSibling;
                    if (cb.checked) {
                        card.style.borderColor = "var(--bs-primary)";
                        card.style.backgroundColor = "rgba(var(--bs-primary-rgb), 0.05)";
                        card.style.boxShadow = "0 8px 25px rgba(0,0,0,0.15)";
                        card.style.transform = "scale(1.02)";
                    } else {
                        card.style.borderColor = "var(--bs-gray-200)";
                        card.style.backgroundColor = "white";
                        card.style.boxShadow = "0 .125rem .25rem rgba(0,0,0,.075)";
                        card.style.transform = "scale(1)";
                    }
                });
            }

            checkboxes.forEach(cb => {
                cb.addEventListener('change', function() {
                    let s = document.querySelectorAll('.cancion-checkbox:checked').length;
                    if (s > 7) {
                        this.checked = false; // Prevent more than 7
                        return;
                    }
                    actualizarEstado();
                });
            });

            form.addEventListener('submit', function(e) {
                let s = document.querySelectorAll('.cancion-checkbox:checked').length;
                if (s < 5 || s > 7) {
                    e.preventDefault();
                    alert("Por favor, selecciona entre 5 y 7 canciones.");
                }
            });

            // Init call to paint the already checked ones
            actualizarEstado();
        });
    </script>
}
