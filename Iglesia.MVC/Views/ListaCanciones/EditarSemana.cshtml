@model IglesiaGPS.modelo.ListaCanciones

@{
    ViewData["Title"] = "Editar Repertorio Semanal";
    var cancionesDisponibles = ViewBag.CancionesDisponibles as List<IglesiaGPS.modelo.Cancion> ?? new List<IglesiaGPS.modelo.Cancion>();
    var preSeleccionadas = ViewBag.Seleccionadas as List<int> ?? new List<int>();
}

<div class="container mt-5">
    <!-- Encabezado de Edición -->
    <div class="d-flex justify-content-between align-items-center mb-4 p-4 rounded neo-header-box" style="position: relative; overflow: hidden; background: rgba(20, 24, 36, 0.7); border: 1px solid rgba(255, 61, 0, 0.3);">
        <!-- Deco Accent Line -->
        <div style="position: absolute; left: 0; top: 0; height: 100%; border-left: 5px solid #ff3d00; box-shadow: 0 0 20px #ff3d00;"></div>
        <div class="ms-md-3">
            <h1 class="display-6 fw-bold mb-1" style="color: #ffffff; text-shadow: 0 0 10px rgba(0, 229, 255, 0.5); letter-spacing: -1px;">Editando Repertorio</h1>
            <h5 style="color: #1de9b6;"><i class="bi bi-music-note-list me-2"></i>@Model.Titulo</h5>
        </div>
        <a asp-controller="Home" asp-action="Index" class="btn neo-btn-outline rounded-pill fw-bold">Volver al Inicio</a>
    </div>

    <!-- Barra de búsqueda -->
    <div class="row mb-5 justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="neo-search-box position-relative shadow-sm rounded-pill p-1 transition-hover">
                <div class="input-group input-group-lg border-0">
                    <span class="input-group-text bg-transparent border-0 ps-4 pe-2" style="color: #ff3d00;">
                        <i class="bi bi-search fs-4" style="text-shadow: 0 0 8px rgba(255, 61, 0, 0.6);"></i>
                    </span>
                    <input type="text" id="searchInput" class="form-control bg-transparent border-0 shadow-none px-2 text-white" placeholder="Busca por título o artista..." aria-label="Buscar canciones">
                    <button class="btn neo-btn-cyan rounded-pill px-4 fw-bold" type="button" onclick="document.getElementById('searchInput').focus()">Buscar</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Datos Ocultos para JavaScript -->
    <input type="hidden" id="listaCancionesId" value="@Model.ListaCancionesId" />
    <script>
        // Inyectar el array de preseleccionadas al script de javascript globalmente
        var preSeleccionadasGlobal = [@string.Join(",", preSeleccionadas)];
    </script>
    @Html.AntiForgeryToken()

    <!-- Cuadrícula de Canciones Disponibles -->
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 row-cols-xl-4 g-4" id="cancionesContainer">
        @foreach (var item in cancionesDisponibles)
        {
            <div class="col cancion-card" data-autor="@item.Autor?.ToLower()" data-titulo="@item.Titulo?.ToLower()">
                <div class="card h-100 border-0 shadow-sm song-panel transition-hover neo-song-panel">
                    <div class="card-body d-flex flex-column text-center p-3">
                        
                        <!-- Contenedor del ícono/foto central interactivo -->
                        <div class="cancion-selector mx-auto mb-3 cancion-img-container" style="cursor: pointer;" >
                            @if (!string.IsNullOrEmpty(item.FotoUrl))
                            {
                                <img src="@item.FotoUrl" class="rounded-circle object-fit-cover shadow-sm cancion-foto neo-img-border" style="width: 70px; height: 70px;" alt="Foto de @item.Autor">
                            }
                            else
                            {
                                <div class="song-icon rounded-circle d-flex align-items-center justify-content-center shadow-sm mx-auto neo-img-border" style="width: 70px; height: 70px; background: rgba(0, 229, 255, 0.1); color: #00e5ff;">
                                    <i class="bi bi-music-note-beamed fs-3 icon-music"></i>
                                </div>
                            }
                            <!-- Etiqueta de orden de selección -->
                            <div class="seleccion-badge d-none position-absolute top-50 start-50 translate-middle text-white rounded-circle fw-bold fs-4 d-flex align-items-center justify-content-center shadow neo-sel-badge" style="width: 70px; height: 70px; z-index: 10;">
                                <span class="seleccion-numero text-white">X</span>
                            </div>
                        </div>

                        <h5 class="card-title fw-bold text-truncate mb-1" title="@item.Titulo" style="font-size: 1.1rem; color: #ffffff;">@item.Titulo</h5>
                        <p class="card-text mb-3" style="font-size: 0.9rem; color: #94a3b8;">
                            <i class="bi bi-person-fill" style="color: #ff3d00;"></i> @(string.IsNullOrEmpty(item.Autor) ? "Desconocido" : item.Autor)
                        </p>
                        
                        <div class="mt-auto">
                            <div class="mb-2 text-start">
                                <span class="badge rounded-pill px-3 py-2 fw-semibold shadow-sm" style="font-size: 0.85rem; background: rgba(0, 229, 255, 0.15); color: #00e5ff; border: 1px solid rgba(0, 229, 255, 0.4);">
                                    Tono: @(string.IsNullOrEmpty(item.Tono) ? "-" : item.Tono)
                                </span>
                            </div>
                            <!-- Meta Boton (Su valor 'data-id' se usa en el javascript para la lógica del arreglo) -->
                            <div class="d-none">
                                <button class="btn-ver-notas" data-id="@item.CancionId" data-titulo="@item.Titulo"></button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<!-- Panel Flotante de Actualización (Siempre visible para Administradores) -->
<div id="panelActualizacion" class="position-fixed bottom-0 start-50 translate-middle-x p-3 mb-4 rounded-pill shadow-lg d-flex align-items-center neo-float-panel" style="z-index: 1050; min-width: 400px;">
    <div class="me-auto d-flex align-items-center">
        <!-- Círculo Contador Neo-Orange -->
        <div class="rounded-circle d-flex align-items-center justify-content-center me-3 neo-counter-circle">
            <span id="contadorActualizadas" class="fw-bold fs-5 shadow-text">0</span>
        </div>
        <span class="fw-bold text-white fs-6">Nuevas Seleccionadas<br><small class="fw-normal" style="font-size:0.75rem; color: #1de9b6;">(Mín 5, Máx 7)</small></span>
    </div>
    <button id="btnActualizarLista" class="btn text-dark rounded-pill fw-bold px-4 ms-2 neo-btn-cyan-solid">
        <i class="bi bi-arrow-clockwise me-1"></i> Actualizar Repertorio
    </button>
</div>

@section Styles {
    <style>
        /* Cyberpunk Variables */
        :root {
            --cyber-bg: #0a0b10;
            --cyber-panel: #12141d;
            --cyber-box: #1a1e2b;
            --cyber-cyan: #00e5ff;
            --cyber-cyan-dim: rgba(0, 229, 255, 0.2);
            --cyber-orange: #ff3d00;
            --cyber-orange-dim: rgba(255, 61, 0, 0.2);
            --cyber-teal: #1de9b6;
        }

        /* Set Background Dark */
        body { 
            background-color: var(--cyber-bg) !important; 
            color: #ffffff !important;
            font-family: 'Inter', 'Segoe UI', sans-serif;
        }
        main { background-color: transparent !important; }

        /* General Header Hover FX */
        .neo-header-box {
            transition: all 0.4s ease;
        }
        .neo-header-box:hover {
            box-shadow: 0 5px 30px rgba(255, 61, 0, 0.1);
            background: rgba(20, 24, 36, 0.9);
        }

        /* Botón Contorno */
        .neo-btn-outline {
            color: var(--cyber-cyan) !important;
            border: 1px solid var(--cyber-cyan) !important;
            background: rgba(0, 229, 255, 0.05);
            transition: all 0.3s ease;
        }
        .neo-btn-outline:hover {
            box-shadow: 0 0 15px var(--cyber-cyan-dim);
            background: rgba(0, 229, 255, 0.15);
            color: #ffffff !important;
        }

        /* Buscador Cyber */
        .neo-search-box {
            background-color: var(--cyber-panel) !important;
            border: 1px solid rgba(255, 255, 255, 0.05);
        }
        .neo-search-box input::placeholder {
            color: rgba(255, 255, 255, 0.3);
        }
        .neo-btn-cyan {
            background: linear-gradient(135deg, #00b4d8, #0077b6);
            color: #ffffff;
            border: 1px solid #00b4d8;
        }
        .neo-btn-cyan:hover {
            box-shadow: 0 0 15px rgba(0, 180, 216, 0.5);
            color: #ffffff;
        }

        /* Paneles de Canción Oscuros */
        .neo-song-panel {
            background-color: var(--cyber-panel) !important;
            border: 1px solid rgba(255,255,255,0.03) !important;
            border-bottom: 2px solid transparent !important;
            border-radius: 12px;
            overflow: hidden;
            transition: all 0.3s ease;
        }
        .transition-hover:hover {
            transform: translateY(-8px);
            background-color: var(--cyber-box) !important;
            border-bottom: 2px solid var(--cyber-cyan) !important; /* Bottom line Neon Accent */
            box-shadow: 0 10px 25px var(--cyber-cyan-dim), 0 0 10px var(--cyber-orange-dim) !important;
        }

        /* Icono e Imagen Redondeada Neón */
        .neo-img-border {
            border: 2px solid rgba(255, 255, 255, 0.1) !important;
            transition: all 0.3s ease;
        }
        .transition-hover:hover .neo-img-border {
            border-color: var(--cyber-cyan) !important;
            box-shadow: 0 0 10px var(--cyber-cyan-dim);
        }

        /* Modulo de Selección Circular Tipo Progreso */
        .neo-sel-badge {
            background-color: rgba(10, 11, 16, 0.9) !important;
            border: 3px solid var(--cyber-orange) !important;
            box-shadow: 0 0 15px var(--cyber-orange), inset 0 0 10px var(--cyber-orange-dim) !important;
            color: #ffffff !important;
        }
        
        /* Panel Flotante Inferior Cyberpunk */
        .neo-float-panel {
            background-color: rgba(17, 19, 26, 0.95) !important;
            backdrop-filter: blur(10px);
            border: 1px solid var(--cyber-cyan) !important;
            box-shadow: 0 -5px 30px var(--cyber-cyan-dim), 0 5px 30px rgba(0,0,0,0.8) !important;
        }
        
        .neo-counter-circle {
            width: 45px; 
            height: 45px;
            background-color: rgba(255, 61, 0, 0.15) !important;
            border: 2px solid var(--cyber-orange) !important;
            color: var(--cyber-orange) !important;
            box-shadow: 0 0 10px var(--cyber-orange-dim), inset 0 0 10px rgba(255, 61, 0, 0.2);
        }

        .neo-btn-cyan-solid {
            background-color: var(--cyber-cyan) !important;
            border: none !important;
            transition: all 0.3s ease;
            box-shadow: 0 0 10px var(--cyber-cyan-dim);
        }
        .neo-btn-cyan-solid:hover {
            background-color: #18ffff !important;
            box-shadow: 0 0 20px rgba(0, 229, 255, 0.6);
            transform: scale(1.03);
        }

        /* Ajustar Footer a modo oscuro para no desentonar */
        .footer {
            background-color: var(--cyber-bg) !important;
            border-top: 1px solid rgba(255, 255, 255, 0.05) !important;
            color: var(--text-muted) !important;
        }
        .footer a {
            color: var(--cyber-cyan) !important;
            text-decoration: none;
        }
    </style>
}

@section Scripts {
    <script src="~/js/editar-semana.js" asp-append-version="true"></script>
}
