@model IglesiaGPS.modelo.NotaMusical
@{
    ViewData["Title"] = "Notas: " + ViewBag.CancionTitulo;
    var usuarioLogueado = Context.Session.GetString("UsuarioNombre");
    var usuarioRol = Context.Session.GetString("UsuarioRol");
}

            <!-- Contenedor Estilo Dashboard Cyberpunk -->
            <div class="cyber-container w-100 mb-5">
                
                <!-- Encabezado Cyberpunk -->
                <div class="cyber-header d-flex justify-content-between align-items-center">
                    <h4 class="mb-0 fw-bold d-flex align-items-center text-truncate" style="color: #00f2fe; text-shadow: 0 0 10px rgba(0, 242, 254, 0.4); font-size: 1.25rem;">
                        <i class="bi bi-music-note-list me-2"></i> @ViewBag.CancionTitulo
                    </h4>
                    
                    <div class="d-flex align-items-center gap-3">
                        @{
                            var url = ViewBag.UrlAudio as string;
                            var videoId = "";
                            if (!string.IsNullOrEmpty(url))
                            {
                                if (url.Contains("v=")) {
                                    videoId = url.Split("v=")[1].Split("&")[0];
                                } else if (url.Contains("youtu.be/")) {
                                    videoId = url.Split("youtu.be/")[1].Split("?")[0];
                                }
                            }
                        }
                        @if (!string.IsNullOrEmpty(videoId))
                        {
                            <button id="btnToggleYoutube" class="btn btn-sm fw-bold cyber-btn-outline" title="Escuchar Canción">
                                <i class="bi bi-youtube text-danger fs-5 me-1"></i> Escuchar
                            </button>
                        }
                        
                        <!-- Botón de regresar -->
                        <a href="javascript:history.back()" class="text-white text-decoration-none btn-close-cyber" title="Cerrar">
                            <i class="bi bi-x-lg"></i>
                        </a>
                    </div>
                </div>

                <!-- Cuerpo Oscuro -->
                <div class="cyber-body">
                    
                    @if (string.IsNullOrEmpty(Model?.Contenido))
                    {
                        <div class="alert alert-warning d-flex align-items-center rounded-3 p-4 border-0" style="background: rgba(255, 170, 0, 0.1); border-left: 4px solid #ffaa00; color: #ffaa00;">
                            <i class="bi bi-exclamation-triangle-fill fs-3 me-3"></i>
                            <div>
                                <h6 class="fw-bold mb-1">Sin Letra o Notas</h6>
                                <p class="mb-0 small">Esta canción aún no tiene contenido de letras/notas configurado.</p>
                            </div>
                        </div>
                    }
                    else
                    {
                        @if (!string.IsNullOrEmpty(Model?.Instrumento))
                        {
                            <div class="instrument-badge mb-3">
                                <span class="badge rounded-pill fw-bold" style="background: rgba(0, 242, 254, 0.1); border: 1px solid rgba(0, 242, 254, 0.5); color: #00f2fe;">
                                    <i class="bi bi-guitar fs-6 me-1"></i> @Model.Instrumento
                                </span>
                            </div>
                        }

                        <!-- Visor Oscuro Cyberpunk -->
                        <div class="viewer-container mb-4">
                            <pre class="cyber-textbox">@Model.Contenido</pre>
                        </div>
                        
                        <!-- Barra Auto-Scroll Lateral -->
                        <div class="auto-scroll-panel shadow-lg d-flex flex-column align-items-center gap-3">
                            <label class="text-uppercase fw-bold m-0" style="color: #00f2fe; font-size: 0.70rem; letter-spacing: 1px;">Scroll</label>
                            
                            <!-- Indicador de velocidad -->
                            <span id="speedValue" class="badge rounded-pill cyber-speed-badge">x5</span>
                            
                            <!-- Rango Vertical (Rotado) -->
                            <div class="range-wrapper">
                                <input type="range" class="form-range cyber-range" id="speedScroll" min="1" max="10" step="1" value="5">
                            </div>

                            <button id="btnAutoScroll" class="btn rounded-circle d-flex align-items-center justify-content-center cyber-play-btn" title="Reproducir Scroll">
                                <i class="bi bi-play-fill fs-3" id="iconAutoScroll" style="margin-left: 2px;"></i>
                            </button>
                        </div>
                    }

                    <!-- Botones de Acción Secundarios -->
                    <div class="d-flex justify-content-between mt-5 pt-4 gap-2" style="border-top: 1px solid rgba(0, 242, 254, 0.2);">
                        <div>
                            @if (usuarioRol == "Director" || usuarioRol == "Desarrollador")
                            {
                                <button type="button" class="btn btn-sm text-white fw-bold cyber-btn-outline-danger" data-bs-toggle="modal" data-bs-target="#confirmDeleteModal">
                                    <i class="bi bi-trash-fill me-1"></i> Eliminar
                                </button>
                            }
                        </div>

                        <div class="d-flex gap-2">
                            @if (usuarioLogueado != null)
                            {
                                <a asp-action="EditarNota" asp-route-id="@Model?.CancionId" class="btn btn-sm fw-bold cyber-btn-outline">
                                    <i class="bi bi-pencil-square me-1"></i>Editar
                                </a>
                            }
                            
                            <a href="javascript:history.back()" class="btn btn-sm btn-secondary text-white fw-bold cyber-btn-solid ps-4 pe-4">
                                Cerrar
                            </a>
                        </div>
                    </div>
                </div>
            </div>

<!-- Modal Confirmación Eliminación -->
@if (usuarioRol == "Director" || usuarioRol == "Desarrollador")
{
    <div class="modal fade" id="confirmDeleteModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg">
                <div class="modal-header text-white" style="background-color: #dc3545;">
                    <h5 class="modal-title fw-bold">Confirmar Eliminación</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body p-4 text-dark">
                    <p class="mb-0 fs-5">
                        <i class="bi bi-exclamation-circle text-danger fs-4 me-2"></i>
                        ¿Eliminar permanentemente la canción <strong>"@ViewBag.CancionTitulo"</strong> y todas sus notas?
                    </p>
                </div>
                <div class="modal-footer pt-0 border-0">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancelar</button>
                    <!-- Formulario de eliminación real hacia CancionesController -->
                    <form asp-controller="Canciones" asp-action="DeleteConfirmed" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model?.CancionId" />
                        <button type="submit" class="btn btn-danger fw-bold">Sí, Eliminar</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
}

@{
    var urlFloating = ViewBag.UrlAudio as string;
    var videoIdFloating = "";
    if (!string.IsNullOrEmpty(urlFloating))
    {
        if (urlFloating.Contains("v=")) {
            videoIdFloating = urlFloating.Split("v=")[1].Split("&")[0];
        } else if (urlFloating.Contains("youtu.be/")) {
            videoIdFloating = urlFloating.Split("youtu.be/")[1].Split("?")[0];
        }
    }
}
@if (!string.IsNullOrEmpty(videoIdFloating))
{
    <!-- Reproductor Flotante Arrastrable -->
    <div id="youtubeFloatingPlayer" class="youtube-floating-player d-none shadow-lg">
        <div class="player-header d-flex justify-content-between align-items-center p-2 drag-handle">
            <span class="fw-bold" style="color:#00f2fe; font-size:0.8rem;"><i class="bi bi-play-circle me-1"></i> Audio Oficial</span>
            <button type="button" class="btn-close btn-close-white btn-close-player" onclick="document.getElementById('youtubeFloatingPlayer').classList.add('d-none')"></button>
        </div>
        <div class="iframe-container">
            <iframe id="youtubeIframe" width="100%" height="100%" src="https://www.youtube.com/embed/@videoIdFloating" title="YouTube video player" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" allowfullscreen></iframe>
        </div>
    </div>
}

@section Styles {
    <style>
        body {
            background-color: #0b1120 !important; /* Fondo general Cyberpunk */
            color: #e2e8f0 !important;
            font-family: 'Inter', sans-serif;
        }

        /* Contenedor Principal Cyberpunk */
        .cyber-container {
            background-color: #0f172a;
            border-radius: 12px;
            overflow: hidden;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
            border: 1px solid rgba(0, 242, 254, 0.2);
        }

        .cyber-header {
            background: linear-gradient(90deg, #0f172a, #1e293b);
            padding: 1rem 1.5rem;
            border-bottom: 2px solid rgba(0, 242, 254, 0.3);
        }

        .btn-close-cyber {
            font-size: 1.5rem;
            opacity: 0.7;
            transition: all 0.3s;
        }
        .btn-close-cyber:hover {
            opacity: 1;
            color: #ef4444 !important;
            text-shadow: 0 0 10px rgba(239, 68, 68, 0.8);
        }

        .cyber-body {
            padding: 2rem 1.5rem;
            background: #0f172a;
        }

        /* Visor de Letras Cyberpunk */
        .cyber-textbox {
            background-color: #090e17; /* Más oscuro para contraste */
            border-radius: 8px;
            padding: 1.8rem;
            color: #00f2fe; /* Letra color neon cian */
            font-family: 'Courier New', Courier, monospace;
            font-size: 1.15rem;
            line-height: 1.8;
            border: 1px solid rgba(0, 242, 254, 0.15);
            box-shadow: inset 0 0 20px rgba(0,0,0,0.8);
            white-space: pre-wrap;
            word-wrap: break-word;
            margin-bottom: 0;
            max-width: 100%;
        }

        /* Botones Cyberpunk */
        .cyber-btn-outline {
            background: transparent;
            color: #00f2fe;
            border: 1px solid rgba(0, 242, 254, 0.5);
            transition: all 0.3s ease;
        }
        .cyber-btn-outline:hover {
            background: rgba(0, 242, 254, 0.1);
            color: #fff;
            box-shadow: 0 0 10px rgba(0, 242, 254, 0.4);
        }

        .cyber-btn-outline-danger {
            background: rgba(239, 68, 68, 0.1);
            color: #ef4444;
            border: 1px solid rgba(239, 68, 68, 0.4);
            transition: all 0.3s ease;
        }
        .cyber-btn-outline-danger:hover {
            background: rgba(239, 68, 68, 0.2);
            color: #fff;
            box-shadow: 0 0 10px rgba(239, 68, 68, 0.5);
        }

        .cyber-btn-solid {
            background: #334155;
            border: 1px solid #475569;
            transition: all 0.3s;
        }
        .cyber-btn-solid:hover {
            background: #475569;
        }

        /* PANEL DE SCROLL FLOTANTE LATERAL */
        .auto-scroll-panel {
            position: fixed;
            top: 50%;
            right: 20px;
            transform: translateY(-50%);
            background: rgba(15, 23, 42, 0.85);
            backdrop-filter: blur(8px);
            border: 1px solid rgba(0, 242, 254, 0.3);
            border-radius: 30px;
            padding: 20px 10px;
            z-index: 1050;
            box-shadow: 0 0 20px rgba(0, 0, 0, 0.5), 0 0 15px rgba(0, 242, 254, 0.1);
        }

        /* Slider Vertical */
        .range-wrapper {
            height: 150px; /* Altura de la barra rotada */
            width: 30px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 10px 0;
        }

        .cyber-range {
            width: 150px; /* Será la altura al rotar */
            height: 6px;
            background: rgba(255,255,255,0.1);
            border-radius: 5px;
            outline: none;
            -webkit-appearance: none;
            transform: rotate(-90deg); /* Voltear para vertical */
            transform-origin: center;
        }

        .cyber-range::-webkit-slider-thumb {
            -webkit-appearance: none;
            width: 18px;
            height: 18px;
            border-radius: 50%;
            background: #00f2fe;
            cursor: pointer;
            box-shadow: 0 0 10px #00f2fe;
        }

        .cyber-speed-badge {
            background: #1e293b;
            color: #00f2fe;
            border: 1px solid rgba(0, 242, 254, 0.3);
            font-size: 0.75rem;
            padding: 5px 8px;
        }

        .cyber-play-btn {
            width: 50px;
            height: 50px;
            background: rgba(0, 242, 254, 0.1);
            color: #00f2fe;
            border: 2px solid #00f2fe;
            transition: all 0.3s;
        }
        .cyber-play-btn:hover {
            background: #00f2fe;
            color: #0f172a;
            box-shadow: 0 0 15px #00f2fe;
        }
        .cyber-play-btn.active {
            background: #00f2fe;
            color: #0f172a;
            box-shadow: 0 0 20px #00f2fe;
        }

        /* Modal Eliminar Estilo Oscuro */
        #confirmDeleteModal .modal-content {
            background: #0f172a;
            border: 1px solid rgba(239, 68, 68, 0.5);
            box-shadow: 0 0 30px rgba(239, 68, 68, 0.15);
        }
        #confirmDeleteModal .modal-header {
            background: rgba(239, 68, 68, 0.1);
            border-bottom: 1px solid rgba(239, 68, 68, 0.2);
        }
        #confirmDeleteModal .modal-body, #confirmDeleteModal .modal-footer {
            background: transparent;
            color: white !important;
        }
        
        /* Ajustar al hacer pequeña la pantalla */
        @@media (max-width: 768px) {
            .auto-scroll-panel {
                right: 10px;
                padding: 15px 5px;
            }
            .cyber-textbox {
                font-size: 1rem;
                padding: 1rem;
            }
            .cyber-play-btn {
                width: 40px; height: 40px;
            }
            .cyber-play-btn i {
                font-size: 1.5rem !important;
            }
        }

        /* Reproductor YouTube Flotante */
        .youtube-floating-player {
            position: fixed;
            bottom: 20px;
            right: 120px;
            width: 350px;
            height: 240px;
            background: rgba(15, 23, 42, 0.95);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(0, 242, 254, 0.4);
            border-radius: 12px;
            z-index: 1060;
            display: flex;
            flex-direction: column;
            overflow: hidden;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.6), 0 0 15px rgba(0, 242, 254, 0.2);
            resize: both;
        }

        .player-header {
            background: linear-gradient(90deg, #0f172a, #1e293b);
            border-bottom: 1px solid rgba(0, 242, 254, 0.3);
            cursor: move;
            user-select: none;
        }
        
        .btn-close-player {
            font-size: 0.6rem;
            opacity: 0.8;
        }

        .iframe-container {
            flex-grow: 1;
            width: 100%;
            height: calc(100% - 35px);
        }

        @@media (max-width: 768px) {
            .youtube-floating-player {
                width: 280px;
                height: 190px;
                right: 70px;
                bottom: 15px;
            }
        }
    </style>
}

@section Scripts {
    <script>
        const btnAutoScroll = document.getElementById('btnAutoScroll');
        const iconAutoScroll = document.getElementById('iconAutoScroll');
        const speedScroll = document.getElementById('speedScroll');
        const speedValue = document.getElementById('speedValue');

        let scrollInterval = null;
        let isScrolling = false;
        let currentSpeed = 5;

        // Formato visual para que el Director entienda la velocidad
        function updateSpeedLabel(val) {
            if (val <= 3) return "Baja x" + val;
            if (val <= 6) return "Media x" + val;
            if (val <= 8) return "Alta x" + val;
            return "Muy Alta x" + val;
        }

        function toggleScroll() {
            if (!btnAutoScroll) return;
            isScrolling = !isScrolling;
            
            if (isScrolling) {
                iconAutoScroll.classList.replace('bi-play-fill', 'bi-pause-fill');
                iconAutoScroll.style.marginLeft = "0px";
                btnAutoScroll.classList.replace('btn-outline-info', 'btn-info');
                btnAutoScroll.classList.add('text-dark');
                startScrolling();
            } else {
                iconAutoScroll.classList.replace('bi-pause-fill', 'bi-play-fill');
                iconAutoScroll.style.marginLeft = "4px";
                btnAutoScroll.classList.replace('btn-info', 'btn-outline-info');
                btnAutoScroll.classList.remove('text-dark');
                stopScrolling();
            }
        }

        function startScrolling() {
            stopScrolling();
            if (!isScrolling) return;

            let delay = Math.max(15, 80 - (currentSpeed * 7)); 
            let px = currentSpeed > 7 ? 2 : 1; 

            scrollInterval = setInterval(() => {
                window.scrollBy({ top: px, left: 0, behavior: 'instant' });
                if (document.body) {
                   document.body.scrollTop += px; 
                   document.documentElement.scrollTop += px;
                }
                
                // Detener en el fondo
                if (Math.ceil(window.innerHeight + window.scrollY) >= document.documentElement.scrollHeight) {
                    toggleScroll();
                }
            }, delay);
        }

        function stopScrolling() {
            if (scrollInterval) clearInterval(scrollInterval);
        }

        if(speedScroll) {
            speedScroll.addEventListener('input', (e) => {
                currentSpeed = parseInt(e.target.value);
                speedValue.textContent = updateSpeedLabel(currentSpeed);
                if (isScrolling) {
                    startScrolling();
                }
            });

            btnAutoScroll.addEventListener('click', toggleScroll);
        }

        // --- Lógica del Reproductor YouTube Flotante ---
        const ytPlayer = document.getElementById('youtubeFloatingPlayer');
        const btnToggleYt = document.getElementById('btnToggleYoutube');

        if (btnToggleYt && ytPlayer) {
            btnToggleYt.addEventListener('click', () => {
                ytPlayer.classList.toggle('d-none');
            });

            const dragHandle = ytPlayer.querySelector('.drag-handle');
            let isDragging = false;
            let currentX;
            let currentY;
            let initialX;
            let initialY;

            dragHandle.addEventListener('mousedown', dragStart);
            document.addEventListener('mouseup', dragEnd);
            document.addEventListener('mousemove', drag);

            dragHandle.addEventListener('touchstart', dragStart, {passive: true});
            document.addEventListener('touchend', dragEnd);
            document.addEventListener('touchmove', drag, {passive: false});

            function dragStart(e) {
                if (e.target === dragHandle || dragHandle.contains(e.target)) {
                    if (e.target.classList.contains('btn-close-player')) return;

                    if (e.type === "touchstart") {
                        initialX = e.touches[0].clientX - ytPlayer.offsetLeft;
                        initialY = e.touches[0].clientY - ytPlayer.offsetTop;
                    } else {
                        initialX = e.clientX - ytPlayer.offsetLeft;
                        initialY = e.clientY - ytPlayer.offsetTop;
                    }
                    isDragging = true;
                }
            }

            function dragEnd(e) {
                isDragging = false;
            }

            function drag(e) {
                if (isDragging) {
                    e.preventDefault(); 
                
                    if (e.type === "touchmove") {
                        currentX = e.touches[0].clientX - initialX;
                        currentY = e.touches[0].clientY - initialY;
                    } else {
                        currentX = e.clientX - initialX;
                        currentY = e.clientY - initialY;
                    }

                    ytPlayer.style.left = currentX + 'px';
                    ytPlayer.style.top = currentY + 'px';
                    ytPlayer.style.bottom = 'auto'; 
                    ytPlayer.style.right = 'auto';
                }
            }
        }
    </script>
}
