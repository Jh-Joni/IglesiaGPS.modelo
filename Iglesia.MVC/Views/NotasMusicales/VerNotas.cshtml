@model IglesiaGPS.modelo.NotaMusical
@{
    ViewData["Title"] = "Notas: " + ViewBag.CancionTitulo;
    var usuarioLogueado = Context.Session.GetString("UsuarioNombre");
}

<div class="container mt-5 mb-5">
    <h2 class="text-primary">Notas de la canción: <span class="text-dark">@ViewBag.CancionTitulo</span></h2>
    <hr />

    <div class="card shadow p-4" style="border-radius: 12px; border-left: 5px solid #2e7d32;">
        @if (string.IsNullOrEmpty(Model.Contenido))
        {
            <div class="alert alert-warning">
                <i class="bi bi-info-circle"></i> Aún no hay notas registradas para esta canción. Has clic en el botón inferior para empezar a editar.
            </div>
        }
        else
        {
            <div style="background: #fdfdfd; padding: 20px; border-radius: 8px; border: 1px solid #eee;">
                <pre style="white-space: pre-wrap; font-family: 'Courier New', Courier, monospace; font-size: 16px; margin: 0; color: #333;">@Model.Contenido</pre>
            </div>
        }

        <div class="mt-4 pt-3 border-top">
            @if (usuarioLogueado != null)
            {
                <a asp-action="EditarNota" asp-route-id="@Model.CancionId" class="btn btn-warning px-4 py-2" style="font-weight: 600;">
                    ✏️ Editar Notas
                </a>
            }
            <a href="javascript:history.back()" class="btn btn-outline-secondary px-4 py-2 ms-2">
                Volver
            </a>
        </div>
    </div>
</div>
