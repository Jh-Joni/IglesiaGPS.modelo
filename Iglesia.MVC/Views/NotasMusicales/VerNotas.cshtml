@model IglesiaGPS.modelo.NotaMusical
@{
    ViewData["Title"] = "Notas: " + ViewBag.CancionTitulo;
    var usuarioLogueado = Context.Session.GetString("UsuarioNombre");
    var usuarioRol = Context.Session.GetString("UsuarioRol");
}

<div class="container mt-4 mb-5 px-3 px-md-4">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-10">
            <!-- Panel Principal Simplificado -->
            <div class="card shadow-sm border-0 rounded-4 overflow-hidden" style="background-color: #0d1b2a;">
                
                <!-- Encabezado -->
                <div class="card-header border-bottom-0 py-3" style="background-color: #1b263b;">
                    <div class="d-flex flex-column flex-sm-row justify-content-between align-items-center gap-2">
                        <h4 class="mb-0 fw-bold d-flex align-items-center text-center text-sm-start" style="color: #7df9ff; letter-spacing: 0.5px;">
                            <i class="bi bi-music-note-list me-2"></i> @ViewBag.CancionTitulo
                        </h4>
                        @if (!string.IsNullOrEmpty(Model?.Instrumento))
                        {
                            <span class="badge rounded-pill px-3 py-2 fw-semibold" style="background-color: #415a77; color: #e0e1dd; font-size: 0.85rem;">
                                Parámetro: @Model.Instrumento
                            </span>
                        }
                    </div>
                </div>

                <!-- Cuerpo de Letras -->
                <div class="card-body p-3 p-md-5">
                    
                    @if (string.IsNullOrEmpty(Model?.Contenido))
                    {
                        <div class="alert alert-warning d-flex align-items-center rounded-3 p-4 border-0" style="background-color: #fff3cd; color: #856404;">
                            <i class="bi bi-exclamation-triangle-fill fs-3 me-3"></i>
                            <div>
                                <h6 class="fw-bold mb-1">Sin Letra o Notas</h6>
                                <p class="mb-0 small">Esta canción aún no tiene contenido de letras/notas configurado.</p>
                            </div>
                        </div>
                    }
                    else
                    {
                        <!-- Visor Elegante y Simple -->
                        <div class="viewer-container p-3 p-md-4 rounded-3 shadow-inner" style="background-color: #081119; border: 1px solid #162a3f;">
                            <pre class="mb-0" style="font-family: 'Inter', 'Segoe UI', sans-serif; font-size: 1.15rem; color: #7df9ff; white-space: pre-wrap; line-height: 1.7; word-wrap: break-word;">@Model.Contenido</pre>
                        </div>
                    }

                    <!-- Botones de Acción -->
                    <div class="d-flex flex-column flex-sm-row justify-content-between align-items-stretch mt-5 pt-4 gap-3 border-top" style="border-color: #1b263b !important;">
                        <a href="javascript:history.back()" class="btn btn-outline-light rounded-pill px-4 py-2 fw-semibold order-last order-sm-first">
                            <i class="bi bi-arrow-left me-2"></i>Regresar
                        </a>

                        <div class="d-flex flex-column flex-sm-row gap-2">
                            @if (usuarioRol == "Director" || usuarioRol == "Desarrollador")
                            {
                                <!-- Botón Eliminar (Visible solo para Director/Desarrollador) -->
                                <button type="button" class="btn rounded-pill px-4 py-2 fw-semibold text-white shadow-sm" style="background-color: #e63946; border: none;" data-bs-toggle="modal" data-bs-target="#confirmDeleteModal">
                                    <i class="bi bi-trash3 me-2"></i>Eliminar
                                </button>
                            }

                            @if (usuarioLogueado != null)
                            {
                                <a asp-action="EditarNota" asp-route-id="@Model?.CancionId" class="btn rounded-pill px-4 py-2 fw-semibold text-dark shadow-sm" style="background-color: #7df9ff; border: none;">
                                    <i class="bi bi-pencil-square me-2"></i>Editar Letra/Notas
                                </a>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal Confirmación Eliminación -->
@if (usuarioRol == "Director" || usuarioRol == "Desarrollador")
{
    <div class="modal fade" id="confirmDeleteModal" tabindex="-1" aria-labelledby="confirmDeleteLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg rounded-4" style="background-color: #1b263b; color: #e0e1dd;">
                <div class="modal-header border-bottom-0">
                    <h5 class="modal-title fw-bold text-white" id="confirmDeleteLabel">Confirmar Eliminación</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body p-4">
                    <p class="mb-0 fs-5">
                        <i class="bi bi-exclamation-circle text-warning fs-4 me-2"></i>
                        ¿Estás seguro de que deseas eliminar permanentemente la canción <strong>"@ViewBag.CancionTitulo"</strong> y todas sus notas?
                    </p>
                    <p class="text-danger small mt-2 fw-bold">Esta acción no se puede deshacer y eliminará la canción de todas las listas.</p>
                </div>
                <div class="modal-footer border-top-0 pt-0">
                    <button type="button" class="btn btn-outline-light rounded-pill px-4" data-bs-dismiss="modal">Cancelar</button>
                    <!-- Formulario de eliminación real hacia CancionesController -->
                    <form asp-controller="Canciones" asp-action="DeleteConfirmed" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model?.CancionId" />
                        <button type="submit" class="btn btn-danger rounded-pill px-4 fw-bold">Sí, Eliminar</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
}

@section Styles {
    <style>
        body {
            background-color: #0b111a !important;
            font-family: 'Inter', sans-serif;
        }
        main {
            background-color: transparent !important;
        }

        /* Responsive Text Viewer */
        .viewer-container pre {
            max-width: 100%;
            overflow-x: auto; /* Evita que el texto salga de la pantalla en teléfonos pequeños */
        }
        
        .shadow-inner {
            box-shadow: inset 0px 4px 10px rgba(0,0,0,0.5);
        }

        /* Hover de botones */
        .btn-outline-light:hover {
            background-color: rgba(255,255,255,0.1);
            color: #fff;
        }
    </style>
}

@section Scripts {
    <script>
        // No se requiere script para animaciones, vista limpia de solo lectura
    </script>
}
