@model IglesiaGPS.modelo.NotaMusical
@{
    ViewData["Title"] = "Editar Notas: " + ViewBag.CancionTitulo;
}

<div class="container mt-5 mb-5">
    <h2 class="text-primary">Editando notas de: <span class="text-dark">@ViewBag.CancionTitulo</span></h2>
    <hr />

    <div class="card shadow p-4" style="border-radius: 12px; border-left: 5px solid #d4af37;">
        <form asp-action="EditarNota" asp-route-id="@Model.CancionId" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="CancionId" />
            
            <div class="form-group mb-4">
                <label asp-for="Contenido" class="control-label fw-bold mb-2 text-secondary">Escribe o pega las notas (acordes y letras) de la canción:</label>
                <textarea asp-for="Contenido" class="form-control" rows="18" style="font-family: 'Courier New', Courier, monospace; font-size: 16px; border: 2px solid #e8e8e8; border-radius: 8px; padding: 15px;" placeholder="Ejemplo:
G          D
Way maker, miracle worker..."></textarea>
                <span asp-validation-for="Contenido" class="text-danger mt-1"></span>
            </div>
            
            <div class="form-group mt-2">
                <button type="submit" class="btn btn-primary px-4 py-2" style="background-color: #0a1f44; border:none; font-weight: 600;">💾 Guardar Cambios</button>
                <a asp-action="VerNotas" asp-route-id="@Model.CancionId" class="btn btn-outline-secondary px-4 py-2 ms-2">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
