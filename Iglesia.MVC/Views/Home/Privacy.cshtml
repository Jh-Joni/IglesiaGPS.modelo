@{
    ViewData["Title"] = "Privacy Policy - Cyber Sec";
}

<div class="row justify-content-center mt-5 mb-5">
    <div class="col-lg-10">
        <!-- Consola de Privacidad Cyberpunk -->
        <div class="neo-terminal-wrapper shadow-lg position-relative rounded-4 overflow-hidden" style="background: var(--cyber-panel); border: 1px solid rgba(0, 229, 255, 0.3);">
            
            <!-- Barra superior de la consola -->
            <div class="neo-terminal-header d-flex justify-content-between align-items-center p-3" style="background: rgba(10, 11, 16, 0.9); border-bottom: 1px solid rgba(0, 229, 255, 0.2);">
                <div class="d-flex align-items-center">
                    <div class="mac-btns me-3">
                        <span class="mac-btn close-btn"></span>
                        <span class="mac-btn min-btn"></span>
                        <span class="mac-btn max-btn"></span>
                    </div>
                    <span class="badge" style="background: transparent; color: #64748b; font-family: monospace; letter-spacing: 2px;">
                        <i class="bi bi-shield-check me-2" style="color: var(--cyber-teal);"></i>SECURITY_PROTOCOL.EXE
                    </span>
                </div>
            </div>

            <div class="neo-terminal-body p-4 p-md-5 position-relative">
                <!-- Efecto de scanline -->
                <div class="scanline"></div>
                
                <h1 class="fw-bold mb-4 neo-glitch-text" id="typewriter-title" style="color: var(--cyber-cyan); text-shadow: 0 0 15px rgba(0, 229, 255, 0.6); font-family: monospace; min-height: 48px;">
                    > _
                </h1>

                <div class="neo-policy-content mt-5" style="display: none; opacity: 0;">
                    <div class="neo-info-block mb-4 p-4 rounded-3" style="background: rgba(29, 233, 182, 0.05); border-left: 4px solid var(--cyber-teal);">
                        <h4 class="fw-bold mb-3" style="color: var(--cyber-teal);"><i class="bi bi-hdd-network me-2"></i>1. Recopilación de Datos</h4>
                        <p style="color: #a9b7c6; line-height: 1.8;">
                            Nuestra aplicación <strong>IglesiaGPS</strong> recopila datos básicos de registro (Nombre, Apellido y Correo Electrónico) exclusivamente para identificar a los usuarios y asignarles roles (Director o Desarrollador). No compartiremos su información con agentes externos ni terceros corporativos sin su consentimiento explícito.<br/>
                            <span class="badge mt-2" style="background: rgba(255, 61, 0, 0.1); color: var(--cyber-orange); border: 1px solid rgba(255, 61, 0, 0.3);">[ DATA_ENCRYPTED ]</span>
                        </p>
                    </div>

                    <div class="neo-info-block mb-4 p-4 rounded-3" style="background: rgba(0, 229, 255, 0.05); border-left: 4px solid var(--cyber-cyan);">
                        <h4 class="fw-bold mb-3" style="color: var(--cyber-cyan);"><i class="bi bi-music-note-list me-2"></i>2. Contenido y Repertorios</h4>
                        <p style="color: #a9b7c6; line-height: 1.8;">
                            Todos los aportes musicales, notas, y listas de canciones creados dentro de la plataforma pertenecen a la base de datos de la iglesia. Los directores de alabanza son responsables del material que publican y no deben infringir derechos de autor sin las debidas licencias (ej. CCLI).
                        </p>
                    </div>

                    <div class="neo-info-block mb-5 p-4 rounded-3" style="background: rgba(255, 61, 0, 0.05); border-left: 4px solid var(--cyber-orange);">
                        <h4 class="fw-bold mb-3" style="color: var(--cyber-orange);"><i class="bi bi-person-badge me-2"></i>3. Roles y Responsabilidad</h4>
                        <p style="color: #a9b7c6; line-height: 1.8;">
                            El acceso a funciones administrativas (Desarrollador, Director) está sujeto a validación manual. Las solicitudes de rol se envían bajo el protocolo de revisión interna. Cualquier uso indebido del sistema o alteraciones no autorizadas a los repertorios resultarán en la revocación inmediata de los privilegios.
                        </p>
                    </div>

                    <hr style="border-color: rgba(0, 229, 255, 0.3); margin: 3rem 0;">

                    <div class="text-center neo-contact-zone p-5 rounded-4 position-relative overflow-hidden" style="border: 1px dashed rgba(29, 233, 182, 0.5);">
                        <!-- Deco background -->
                        <div style="position: absolute; top: 0; left: 0; right: 0; bottom: 0; background: radial-gradient(circle, rgba(29, 233, 182, 0.1) 0%, transparent 70%); pointer-events: none;"></div>
                        
                        <h3 class="fw-bold mb-4 position-relative z-1" style="color: #ffffff; text-shadow: 0 0 10px rgba(255, 255, 255, 0.5);">
                            <i class="bi bi-envelope-at-fill me-2" style="color: var(--cyber-teal);"></i>Contacto de Soporte Total
                        </h3>
                        <p class="mb-4 position-relative z-1" style="color: #94a3b8; font-size: 1.1rem;">
                            Si tienes dudas sobre nuestras políticas o requieres asistencia técnica o reportar una vulnerabilidad, comunícate a nuestros correos de sistemas:
                        </p>
                        
                        <div class="d-flex flex-column flex-md-row justify-content-center gap-4 position-relative z-1">
                            <a href="mailto:jsdiazy@utn.edu.ec" class="neo-contact-card text-decoration-none p-3 rounded-3 d-flex align-items-center justify-content-center flex-grow-1" style="background: rgba(10, 11, 16, 0.8); border: 1px solid rgba(255, 255, 255, 0.1);">
                                <i class="bi bi-envelope-paper-fill fs-4 me-3" style="color: var(--cyber-cyan);"></i>
                                <span class="fw-bold text-white font-monospace">jsdiazy@utn.edu.ec</span>
                            </a>
                            <a href="mailto:jonatanmcs60@gmail.com" class="neo-contact-card text-decoration-none p-3 rounded-3 d-flex align-items-center justify-content-center flex-grow-1" style="background: rgba(10, 11, 16, 0.8); border: 1px solid rgba(255, 255, 255, 0.1);">
                                <i class="bi bi-google fs-4 me-3" style="color: var(--cyber-orange);"></i>
                                <span class="fw-bold text-white font-monospace">jonatanmcs60@gmail.com</span>
                            </a>
                        </div>
                    </div>
                </div>
                
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        :root {
            --cyber-bg: #0a0b10;
            --cyber-panel: #12141d;
            --cyber-cyan: #00e5ff;
            --cyber-orange: #ff3d00;
            --cyber-teal: #1de9b6;
        }
        
        body { 
            background-color: var(--cyber-bg) !important; 
            font-family: 'Inter', sans-serif;
            color: #ffffff;
        }

        /* Mac Console Buttons */
        .mac-btns { display: flex; gap: 6px; }
        .mac-btn { width: 12px; height: 12px; border-radius: 50%; opacity: 0.8; }
        .close-btn { background: #ff5f56; }
        .min-btn { background: #ffbd2e; }
        .max-btn { background: #27c93f; }

        /* Scanline effect */
        .scanline {
            width: 100%;
            height: 100px;
            z-index: 10;
            position: absolute;
            pointer-events: none;
            background: linear-gradient(to bottom, rgba(255,255,255,0), rgba(0, 229, 255, 0.1) 50%, rgba(0,0,0,0));
            top: -100px;
            left: 0;
            animation: scanline 6s linear infinite;
            opacity: 0.5;
        }
        
        @@keyframes scanline {
            0% { top: -100px; }
            100% { top: 100%; }
        }

        /* Glitch / Cursor blinking */
        .cursor-blink {
            animation: blink 1s step-end infinite;
        }
        @@keyframes blink {
            50% { opacity: 0; }
        }

        /* Info blocks hover */
        .neo-info-block {
            transition: all 0.3s ease;
        }
        .neo-info-block:hover {
            transform: translateX(10px);
            background: rgba(255, 255, 255, 0.05) !important;
        }

        /* Contact cards */
        .neo-contact-card {
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
        }
        .neo-contact-card::before {
            content: '';
            position: absolute;
            top: 0; left: -100%; width: 50%; height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.1), transparent);
            transition: all 0.5s;
        }
        .neo-contact-card:hover {
            border-color: var(--cyber-cyan) !important;
            box-shadow: 0 0 20px rgba(0, 229, 255, 0.2);
            transform: translateY(-5px);
        }
        .neo-contact-card:hover::before {
            left: 100%;
        }
        
        /* Entrance animation */
        .fade-in-up {
            animation: fadeInUp 0.8s forwards ease-out;
        }
        @@keyframes fadeInUp {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }
    </style>
}

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Typewriter Effect para el Título
            const titleElement = document.getElementById('typewriter-title');
            const targetText = "> PRIVACIDAD Y PROTOCOLOS DE SEGURIDAD";
            const speed = 60; // milisegundos por caracter
            let i = 0;
            
            titleElement.innerHTML = '> '; // Iniciar limpio
            
            function typeWriter() {
                if (i < targetText.length) {
                    titleElement.innerHTML = targetText.substring(0, i+1) + '<span class="cursor-blink" style="color: var(--cyber-cyan);">_</span>';
                    i++;
                    setTimeout(typeWriter, speed);
                } else {
                    // Al terminar, revelar el contenido con estilo
                    const content = document.querySelector('.neo-policy-content');
                    content.style.display = 'block';
                    content.classList.add('fade-in-up');
                }
            }
            
            // Iniciar efecto después de un pequeño retraso
            setTimeout(typeWriter, 500);
        });
    </script>
}
