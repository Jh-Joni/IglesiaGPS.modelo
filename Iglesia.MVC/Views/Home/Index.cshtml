@{
    ViewData["Title"] = "Home Page";
    var anuncios = ViewBag.Anuncios as List<IglesiaGPS.modelo.Anuncio> ?? new List<IglesiaGPS.modelo.Anuncio>();
    var usuarioLogueado = Context.Session.GetString("UsuarioNombre");
}

    <!-- HERO REDISEÑADO -->
    <section class="hero-nuevo">
        <div class="hero-content">
            <!-- IZQUIERDA: Información -->
            <div class="hero-info">
                <div class="hero-badge">🎵 Ministerio de Alabanza</div>
                <h1>@ViewBag.SemanaActual Semana<br>del Mes de <span>@ViewBag.MesActual</span></h1>
                <p class="hero-subtitle">Preparados para adorar con excelencia</p>
                <div class="hero-fecha">
                    <span class="fecha-icon">📅</span>
                    <div>
                        <span class="fecha-label">Fecha de hoy</span>
                        <span class="fecha-valor">@ViewBag.FechaHoy</span>
                    </div>
                </div>
            </div>

            <!-- SEPARADOR -->
            <div class="hero-separador"></div>

            <!-- DERECHA: Anuncios -->
            @{
                bool hayAnunciosRecientes = anuncios.Any(a => (DateTime.UtcNow - a.FechaCreacion).TotalDays <= 3);
            }
            <div class="hero-anuncios @(hayAnunciosRecientes ? "neon-anuncios-recientes" : "")">
                <div class="hero-anuncios-header">
                    <div class="hero-anuncios-titulo">Anuncios de la Semana</div>
                    @if (usuarioLogueado != null)
                    {
                        <button class="btn-escribir" onclick="abrirModal()" title="Escribir anuncio">✏️</button>
                    }
                </div>

                <div class="hero-anuncios-lista">
                    @if (anuncios.Count == 0)
                    {
                        <div class="sin-anuncios-hero">
                            ✨ No hay anuncios esta semana<br>
                            @if (usuarioLogueado != null)
                            {
                                <span>Pulsa ✏️ para publicar uno</span>
                            }
                            else
                            {
                                <span><a href="@Url.Action("Login", "Auth")" style="color:#d4af37; text-decoration:none;">Inicia sesión</a> para publicar</span>
                            }
                        </div>
                    }
                    else
                    {
                        @foreach (var anuncio in anuncios)
                        {
                            var tipoClass = anuncio.Tipo == "Versículo" ? "mini-tipo-versiculo" :
                                            anuncio.Tipo == "Mensaje" ? "mini-tipo-mensaje" : "mini-tipo-anuncio";
                            var tipoIcon = anuncio.Tipo == "Versículo" ? "📖" :
                                           anuncio.Tipo == "Mensaje" ? "💬" : "📢";

                            <div class="mini-anuncio">
                                <div class="mini-anuncio-top">
                                    <span class="mini-tipo @tipoClass">@tipoIcon @anuncio.Tipo</span>
                                    <span class="mini-autor">@anuncio.Autor</span>
                                </div>
                                <div class="mini-contenido">@anuncio.Contenido</div>
                                <div class="mini-fecha-meta">
                                    <span class="mini-fecha">@anuncio.FechaCreacion.ToString("dd MMM, HH:mm")</span>
                                    @if (usuarioLogueado == anuncio.Autor)
                                    {
                                        <form method="post" asp-action="EliminarAnuncio" asp-controller="Home" style="display:inline; margin:0;">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@anuncio.AnuncioID" />
                                            <button type="submit" class="mini-eliminar">✕</button>
                                        </form>
                                    }
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
    </section>

    <!-- MODAL PARA ESCRIBIR ANUNCIOS -->
    @if (usuarioLogueado != null)
    {
        <div class="modal-overlay" id="modalAnuncio">
            <div class="modal-anuncio">
                <div class="modal-header">
                    <h3>✏️ Nuevo Anuncio</h3>
                    <button class="modal-cerrar" onclick="cerrarModal()">✕</button>
                </div>
                <form method="post" asp-action="CrearAnuncio" asp-controller="Home">
                    @Html.AntiForgeryToken()
                    <textarea class="modal-textarea" name="contenido" placeholder="Escribe tu anuncio, versículo o mensaje para esta semana..." required></textarea>
                    <div class="modal-actions">
                        <select class="modal-select" name="tipo">
                            <option value="Anuncio">📢 Anuncio</option>
                            <option value="Versículo">📖 Versículo</option>
                            <option value="Mensaje">💬 Mensaje</option>
                        </select>
                        <button type="submit" class="modal-btn">Publicar</button>
                    </div>
                </form>
                <p class="modal-nota">Los anuncios se eliminan automáticamente después de 7 días</p>
            </div>
        </div>
    }

    <!-- ALERTA DE RECOMENDACIONES (Cyberpunk Orange) -->
    @if ((Context.Session.GetString("UsuarioRol") == "Director" || Context.Session.GetString("UsuarioRol") == "Desarrollador") && ViewBag.TotalRecomendacionesPendientes > 0)
    {
        <div class="container my-4" style="max-width: 900px;">
            <div class="alert shadow-lg d-flex align-items-center justify-content-between p-3" style="background: rgba(255, 170, 0, 0.1); border: 1px solid rgba(255, 170, 0, 0.5); border-left: 4px solid #ffaa00; border-radius: 12px; backdrop-filter: blur(5px);">
                <div>
                    <i class="bi bi-broadcast fs-4 me-3" style="color: #ffaa00; text-shadow: 0 0 10px #ffaa00;"></i>
                    <span style="color: #e2e8f0; font-size: 1.05rem;">
                        <strong>¡Señal Recibida!</strong> Hay <span style="color: #ffaa00; font-weight: bold; font-family: monospace; font-size: 1.1rem;">@ViewBag.TotalRecomendacionesPendientes</span> canciones recomendadas esperando revisión.
                    </span>
                </div>
                <a asp-controller="Recomendaciones" asp-action="Index" class="btn btn-sm btn-outline-warning fw-bold rounded-pill shadow-sm" style="transition: all 0.3s; white-space: nowrap;">
                    IR A PANEL <i class="bi bi-arrow-right-short"></i>
                </a>
            </div>
        </div>
    }

    <!-- HISTORIAL DE ALABANZAS POR SEMANA -->
    <section class="historial-section">
        @{
            var listasMusicalesRaw = ViewBag.ListasMusicales as List<IglesiaGPS.modelo.ListaCanciones> ?? new List<IglesiaGPS.modelo.ListaCanciones>();
            var listasPadre = listasMusicalesRaw.Where(l => !l.Titulo.StartsWith("Miércoles_")).ToList();
            bool existePublicada = listasPadre.Any(l => l.Publicada);

            // Lógica robusta para determinar el límite de la semana activa (Domingo 19:00)
            var ahora = DateTime.Now;
            
            // Encontrar el domingo MÁS CERCANO en el pasado o presente como inicio (Día 0)
            int diasDesdeDomingo = (int)ahora.DayOfWeek;
            var domingoAnterior = ahora.Date.AddDays(-diasDesdeDomingo);
            
            var corteSemana = domingoAnterior.AddDays(7).AddHours(19); // Próximo domingo a las 19:00

            // Si ya pasamos de este domingo a las 19:00, la semana corta el SIGUIENTE domingo
            if (ahora >= corteSemana)
            {
                corteSemana = corteSemana.AddDays(7);
            }
            
            var inicioSemana = corteSemana.AddDays(-7); // El límite inferior es exactamente 7 días antes del corte
        }

        <h2>📋 Alabanzas de la Semana</h2>
        <p class="historial-subtitulo">Repertorio principal elegido por nuestros Directores</p>

        @if (listasPadre.Count == 0)
        {
            <div class="historial-vacio">
                🎵 No hay repertorios creados todavía.<br>
                <span class="text-muted" style="font-size:13px;">Los directores pueden crear el repertorio semanal desde el panel y aparecerá aquí automáticamente.</span>
            </div>
        }
        else
        {
            @for (int i = 0; i < listasPadre.Count; i++)
            {
                var lista = listasPadre[i];
                var esActiva = lista.Publicada || (!existePublicada && i == 0);
                var colorClase = esActiva ? "lista-activa" : "lista-pasada";
                
                // Extraer detalles de forma segura
                var detalles = lista.Detalles?.OrderBy(d => d.Orden).ToList() ?? new List<IglesiaGPS.modelo.ListaCancionDetalle>();
                var creador = lista.Director != null ? lista.Director.Nombre : "Director";

                // Encontrar la lista de Miércoles asociada
                string tituloMiercoles = $"Miércoles_{lista.ListaCancionesId}";
                var listaMiercoles = listasMusicalesRaw.FirstOrDefault(l => l.Titulo == tituloMiercoles);
                var detallesMiercoles = listaMiercoles?.Detalles?.OrderBy(d => d.Orden).ToList() ?? new List<IglesiaGPS.modelo.ListaCancionDetalle>();

                <div class="historial-lista @colorClase" data-index="@i">
                    <div class="historial-lista-header" onclick="toggleSemana(@i)">
                        <div class="historial-lista-info">
                            <div class="d-flex align-items-center mb-2 flex-wrap">
                                @if (esActiva)
                                { 
                                    <span class="estado-badge badge-activa me-2">🟢 DOMINGO ACTUAL</span> 
                                }
                                else
                                { 
                                    <span class="estado-badge badge-pasada me-2">🔴 DOMINGO ANTERIOR</span> 
                                }
                            </div>
                            
                            <div class="d-flex align-items-center flex-wrap gap-2 mt-2 mb-1" onclick="event.stopPropagation();">
                                @if (esActiva)
                                {
                                    <a asp-controller="Home" asp-action="DescargarPdfListaActiva" asp-route-id="@lista.ListaCancionesId" class="btn btn-sm text-white rounded-pill fw-bold" style="background-color: #d4af37;" target="_blank">
                                        <i class="bi bi-file-earmark-pdf"></i> PDF Domingo
                                    </a>
                                    @if (Context.Session.GetString("UsuarioRol") == "Director" || Context.Session.GetString("UsuarioRol") == "Desarrollador")
                                    {
                                        <a asp-controller="ListaCanciones" asp-action="EditarSemana" asp-route-id="@lista.ListaCancionesId" class="btn btn-sm text-white rounded-pill fw-bold" style="background-color: #0D6845;">
                                            <i class="bi bi-pencil-square"></i> Editar Dom
                                        </a>
                                        <a asp-controller="ListaCanciones" asp-action="EditarMiercoles" asp-route-id="@lista.ListaCancionesId" class="btn btn-sm btn-outline-warning rounded-pill fw-bold" style="border-width: 2px;">
                                            <i class="bi bi-gear-fill"></i> Armar Miércoles
                                        </a>
                                    }
                                }
                                @if (detallesMiercoles.Count > 0)
                                {
                                    <button id="btn-miercoles-@i" class="btn btn-sm btn-warning text-dark fw-bold rounded-pill shadow-sm px-3" onclick="switchTab(@i, 'miercoles')">
                                        Ver Miércoles <i class="bi bi-arrow-right-circle"></i>
                                    </button>
                                    <button id="btn-domingo-@i" class="btn btn-sm btn-info text-dark fw-bold rounded-pill shadow-sm px-3 d-none" onclick="switchTab(@i, 'domingo')" style="background-color:#38bdf8; border:none;">
                                        <i class="bi bi-arrow-left-circle"></i> Ver Domingo
                                    </button>
                                }
                            </div>
                            
                            <h3 class="mt-2 text-white">@lista.Titulo</h3>
                            <div class="historial-meta mt-1 mb-2">
                                <span>🎵 @detalles.Count canciones dom.</span>
                                <span>📅 @lista.FechaCreacion.ToString("dd/MM/yyyy")</span>
                                <span class="fw-bold text-dark"><i class="bi bi-person-badge"></i> Por: @creador</span>
                            </div>
                        </div>
                        <span class="toggle-icon" id="toggle-icon-@i">@(esActiva ? "▼" : "▶")</span>
                    </div>

                    <div class="canciones-wrapper @(esActiva ? "expandido" : "colapsado")" id="canciones-@i">
                        
                        <!-- CONTENEDOR DE DOMINGO -->
                        <div class="canciones-container mt-2" id="grid-domingo-@i">
                            <div class="mb-3 mt-1 pb-2 border-bottom border-secondary">
                                <h5 class="fw-bold m-0 text-white text-center text-sm-start">
                                    <i class="bi bi-calendar-check text-success"></i> Lista del Domingo
                                </h5>
                            </div>
                            @if (detalles.Count == 0)
                            {
                                <div class="text-muted small mt-2">Esta lista se guardó sin canciones vinculadas.</div>
                            }
                            else
                            {
                                foreach (var det in detalles)
                                {
                                    var cancion = det.Cancion;
                                    if (cancion == null) continue;

                                    <div class="cancion-card @(esActiva ? "" : "card-pasada")" style="animation-delay: @(detalles.IndexOf(det) * 0.1)s">
                                        <div>
                                            <h3 class="text-truncate" title="@cancion.Titulo">@cancion.Titulo</h3>
                                            <p>Autor: @(string.IsNullOrEmpty(cancion.Autor) ? "Desconocido" : cancion.Autor)</p>
                                            @if (!string.IsNullOrEmpty(cancion.Tono))
                                            {
                                                <p class="tono-info" style="color:@(esActiva ? "var(--bs-success)" : "var(--bs-danger)")">🎼 Tono: @cancion.Tono</p>
                                            }
                                        </div>
                                        <div class="botones mt-3">
                                            <a asp-controller="NotasMusicales" asp-action="VerNotas" asp-route-id="@cancion.CancionId" class="btn btn-notas shadow-sm" >Ver notas</a>
                                            @if (!string.IsNullOrEmpty(cancion.UrlAudio))
                                            {
                                                <button class="secundario shadow-sm" onclick="abrirYoutubeFlotante('@cancion.UrlAudio')">Escuchar</button>
                                            }
                                        </div>
                                    </div>
                                }
                            }
                        </div>
                        
                        <!-- INCIO SUB-PANEL DE MIERCOLES (OCULTO POR DEFECTO) -->
                        @if (detallesMiercoles.Count > 0)
                        {
                            <div class="canciones-container mt-2 d-none" id="grid-miercoles-@i">
                                <div class="d-flex flex-column flex-md-row justify-content-between align-items-strecth align-items-md-center mb-3 mt-1 pb-3 border-bottom gap-3" style="border-color: rgba(234, 179, 8, 0.4) !important;">
                                    <h5 class="fw-bold m-0 text-center text-md-start" style="color: #fde047;">
                                        <i class="bi bi-calendar3-week text-warning"></i> Lista del Miércoles
                                    </h5>
                                    <div class="d-flex flex-column flex-sm-row gap-2 justify-content-center" style="z-index: 10;">
                                        <a asp-controller="Home" asp-action="DescargarPdfListaActiva" asp-route-id="@listaMiercoles.ListaCancionesId" class="btn btn-sm btn-warning text-dark fw-bold rounded-pill shadow-sm w-100 w-sm-auto" target="_blank">
                                            <i class="bi bi-file-earmark-pdf"></i> PDF Mié.
                                        </a>
                                        @if (Context.Session.GetString("UsuarioRol") == "Director" || Context.Session.GetString("UsuarioRol") == "Desarrollador")
                                        {
                                            <a asp-controller="ListaCanciones" asp-action="EditarMiercoles" asp-route-id="@lista.ListaCancionesId" class="btn btn-sm btn-outline-warning fw-bold rounded-pill w-100 w-sm-auto">
                                                <i class="bi bi-pencil"></i> Editar
                                            </a>
                                        }
                                    </div>
                                </div>
                                
                                <div class="contenedor-scroll-invisible mt-3">
                                    @foreach (var detMiercoles in detallesMiercoles)
                                    {
                                        var cancionMi = detMiercoles.Cancion;
                                        if (cancionMi == null) continue;

                                        <div class="cancion-card cancion-miercoles card-pasada shadow-sm" style="background: rgba(234, 179, 8, 0.05); border-color: rgba(234, 179, 8, 0.2); animation-delay: 0s">
                                            <div>
                                                <h3 style="color: #fde047;" class="text-truncate" title="@cancionMi.Titulo">@cancionMi.Titulo</h3>
                                                <p style="color: #cbd5e1;" class="text-truncate">Autor: @(string.IsNullOrEmpty(cancionMi.Autor) ? "Desconocido" : cancionMi.Autor)</p>
                                                @if (!string.IsNullOrEmpty(cancionMi.Tono))
                                                {
                                                    <p class="tono-info" style="color: #eab308;">🎼 Tono: @cancionMi.Tono</p>
                                                }
                                            </div>
                                            <div class="botones mt-auto pt-3">
                                                <a asp-controller="NotasMusicales" asp-action="VerNotas" asp-route-id="@cancionMi.CancionId" class="btn btn-sm text-dark fw-bold shadow-sm" style="background: #eab308;">Ver notas</a>
                                                @if (!string.IsNullOrEmpty(cancionMi.UrlAudio))
                                                {
                                                    <button class="secundario shadow-sm border-warning text-warning" onclick="abrirYoutubeFlotante('@cancionMi.UrlAudio')">Escuchar</button>
                                                }
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                        <!-- FIN SUB-PANEL MIERCOLES -->
                    </div>
                </div>
            }
        }
    </section>


    <!-- FOOTER -->
    @section Styles {
        <style>
            /* Forzar fondo oscuro profundo exclusivo para la pantalla de inicio */
            body { 
                background-color: #0b1120 !important; 
                color: #e2e8f0 !important;
            }
            /* Eliminar fondos blancos del layout maestro si los hay */
            main { 
                background-color: transparent !important; 
            }
            
            /* ====== ESTILOS MODIFICADOS HOME ====== */

            /* Estilizar el footer para integrarlo con el neón */
            .footer {
                background-color: #0b1120 !important;
                border-top: 1px solid rgba(0, 242, 254, 0.2) !important;
                color: #475569 !important;
                box-shadow: 0 -10px 30px rgba(0, 242, 254, 0.05);
            }
            .footer a {
                color: #00f2fe !important;
                text-decoration: none;
                transition: 0.3s;
            }
            .footer a:hover {
                text-shadow: 0 0 10px rgba(0, 242, 254, 0.6);
                color: #ffffff !important;
            }
            /* Clase especial para la card the miercoles */
            .cancion-miercoles:hover {
                transform: translateY(-5px);
                border-color: #eab308 !important;
                box-shadow: 0 10px 20px rgba(234, 179, 8, 0.15) !important;
            }
        </style>

        <style>
            /* BORDE DE NEON PARA CONTENEDOR DE ANUNCIOS */
            .neon-anuncios-recientes {
                position: relative;
                background: rgba(8, 14, 20, 0.95);
                border-radius: 20px;
                border: 2px solid #00f2fe;
                box-shadow: 0 0 20px rgba(0, 242, 254, 0.2);
                z-index: 1;
            }
            
            /* SCROLL ESTILIZADO PARA MIÉRCOLES */
            .contenedor-scroll-invisible {
                display: flex;
                flex-wrap: nowrap;
                overflow-x: auto;
                overflow-y: hidden;
                gap: 15px;
                padding-bottom: 15px; /* Espacio extra para el scroll visible */
                scroll-behavior: smooth;
            }
            
            /* Diseño de barra Dark/Cyberpunk para Chrome, Safari */
            .contenedor-scroll-invisible::-webkit-scrollbar {
                height: 8px; /* grosor del scroll horizontal */
            }
            .contenedor-scroll-invisible::-webkit-scrollbar-track {
                background: rgba(15, 23, 42, 0.5); /* fondo oscuro del camino */
                border-radius: 10px;
            }
            .contenedor-scroll-invisible::-webkit-scrollbar-thumb {
                background: rgba(148, 163, 184, 0.4); /* Botón del scroll gris plomo */
                border-radius: 10px;
            }
            .contenedor-scroll-invisible::-webkit-scrollbar-thumb:hover {
                background: rgba(148, 163, 184, 0.8);
            }
            
            /* Ajuste Flexible a las tarjetas dentro del Scroll */
            .contenedor-scroll-invisible > .cancion-card {
                flex: 0 0 auto;
                width: 250px; /* Ancho fijo para mantener simetría al deslizar */
                display: flex;
                flex-direction: column;
            }
            
            @@media (max-width: 576px) {
                .contenedor-scroll-invisible > .cancion-card {
                    width: 85%; /* En móvil ocupa casi todo el ancho, dejando ver un pedazo de la que sigue */
                }
            }
        </style>
    }

    @section Scripts {
        <script src="~/js/home-index.js" asp-append-version="true"></script>
    }
}
