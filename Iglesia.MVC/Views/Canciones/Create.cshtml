@model IglesiaGPS.modelo.Cancion

@{
    ViewData["Title"] = "Nueva Canción";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="card shadow-lg border-0 neo-card">
                <div class="card-header neo-header text-center py-4">
                    <h2 class="mb-0 fw-bold neon-title"><i class="bi bi-music-note-list me-2"></i>Registrar Nueva Canción</h2>
                    <p class="mb-0 neo-subtitle">Ingresa los datos de la alabanza y opcionalmente sus notas musicales</p>
                </div>
                
                <div class="card-body p-5">
                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger shadow-sm"><i class="bi bi-exclamation-triangle-fill me-2"></i>@ViewBag.Error</div>
                    }

                    <form asp-action="Create" method="post" enctype="multipart/form-data">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="row g-4 mb-4">
                            <!-- Columna Izquierda: Información Principal -->
                            <div class="col-md-6 border-end border-secondary border-opacity-25 pe-4">
                                <h5 class="neo-section-title pb-2 mb-4"><i class="bi bi-info-circle me-2 neo-icon"></i>Información Principal</h5>

                                <!-- Inputs ocultos para validación de modelo si son requeridos internamente o mapeados -->
                                <input type="hidden" asp-for="FechaCreacion" />
                                <input type="hidden" asp-for="CreadoPorUsuarioId" value="0" />

                                <div class="form-floating neo-floating mb-3">
                                    <input asp-for="Titulo" class="form-control neo-input" placeholder="Título de la canción" required />
                                    <label asp-for="Titulo" class="neo-label">Título <span class="text-danger">*</span></label>
                                    <span asp-validation-for="Titulo" class="text-danger small"></span>
                                </div>

                                <div class="form-floating neo-floating mb-3">
                                    <input asp-for="Autor" class="form-control neo-input" placeholder="Autor o Interprete" required />
                                    <label asp-for="Autor" class="neo-label">Autor / Artista <span class="text-danger">*</span></label>
                                    <span asp-validation-for="Autor" class="text-danger small"></span>
                                </div>

                                <div class="row g-2 mb-3">
                                    <div class="col-md-5">
                                        <div class="form-floating neo-floating">
                                            <input asp-for="Tono" class="form-control neo-input" placeholder="Ej: Do Mayor, G, Am..." />
                                            <label asp-for="Tono" class="neo-label">Tono</label>
                                            <span asp-validation-for="Tono" class="text-danger small"></span>
                                        </div>
                                    </div>
                                    <div class="col-md-7">
                                        <div class="form-floating neo-floating">
                                            <input asp-for="UrlAudio" class="form-control neo-input" type="text" placeholder="Enlace a YouTube o Audio" />
                                            <label asp-for="UrlAudio" class="neo-label">Enlace a YouTube</label>
                                            <span asp-validation-for="UrlAudio" class="text-danger small"></span>
                                        </div>
                                    </div>
                                </div>

                                <div class="form-group mb-2">
                                    <label for="FotoFile" class="form-label fw-bold neo-label-file"><i class="bi bi-image me-2 neo-icon"></i>Foto (Opcional, máx. 10 MB)</label>
                                    <input type="file" name="FotoFile" id="FotoFileCreate" class="form-control form-control-sm neo-input-file" accept="image/*" />
                                    <div class="mt-1 small" id="create-file-info"></div>
                                </div>
                            </div>

                            <!-- Columna Derecha: Notas Musicales -->
                            <div class="col-md-6 ps-4">
                                <h5 class="neo-section-title pb-2 mb-4"><i class="bi bi-music-note me-2 neo-icon"></i>Notas Musicales</h5>
                                <p class="neo-subtitle small mb-3">Agrega acordes o tablaturas para esta canción.</p>

                                <div class="neo-inner-panel p-3 rounded-3 shadow-sm border-0 h-100 d-flex flex-column" style="min-height: 250px;">
                                    <div class="form-floating neo-floating mb-3">
                                        <input type="text" name="Instrumento" class="form-control neo-input" placeholder="Ej: Guitarra, Piano, Bajo..." />
                                        <label for="Instrumento" class="neo-label">Instrumento</label>
                                    </div>

                                    <div class="form-floating neo-floating flex-grow-1">
                                        <textarea name="NotaContenido" class="form-control neo-input font-monospace h-100" placeholder="Escribe aquí los acordes..." style="min-height: 15rem;"></textarea>
                                        <label for="NotaContenido" class="neo-label">Acordes / Tablatura</label>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex justify-content-between align-items-center mt-5 pt-3 border-top border-secondary border-opacity-25">
                            <a asp-action="Index" class="btn neo-btn-outline px-4 rounded-pill shadow-sm">
                                <i class="bi bi-arrow-left me-2"></i>Volver
                            </a>
                            <button type="submit" class="btn neo-btn-primary px-5 rounded-pill shadow-sm fw-bold">
                                <i class="bi bi-save me-2"></i>Guardar Canción
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        /* Variables principales Dark Dashboard & Neon Green */
        :root {
            --dark-bg: #0f1115;
            --panel-bg: #1c1f26;
            --panel-inner: #15181e;
            --neon-green: #00e676;
            --neon-green-dim: rgba(0, 230, 118, 0.2);
            --text-main: #e2e8f0;
            --text-muted: #8b9bb4;
            --border-color: #2a2f3a;
        }

        /* Forzar fondo de pantalla completa y del footer */
        body { 
            background-color: var(--dark-bg) !important; 
            color: var(--text-main) !important;
            font-family: 'Inter', 'Segoe UI', sans-serif;
        }
        main { background-color: transparent !important; }

        /* Tarjeta principal */
        .neo-card {
            background-color: var(--panel-bg);
            border: 1px solid var(--border-color) !important;
            border-radius: 16px;
        }
        .neo-header {
            background-color: transparent !important;
            border-bottom: 1px solid var(--border-color);
        }
        .neon-title {
            color: #ffffff;
            letter-spacing: -0.5px;
        }
        .neo-subtitle {
            color: var(--text-muted);
            font-size: 0.95rem;
        }

        /* Secciones y Textos */
        .neo-section-title {
            color: #ffffff;
            border-bottom: 1px solid var(--border-color);
            display: flex;
            align-items: center;
        }
        .neo-icon {
            color: var(--neon-green);
            text-shadow: 0 0 10px var(--neon-green-dim);
        }
        .neo-inner-panel {
            background-color: var(--panel-inner) !important;
            border: 1px solid var(--border-color) !important;
        }

        /* Formularios (Inputs, Selects, Textareas) */
        .neo-input {
            background-color: var(--dark-bg) !important;
            border: 1px solid var(--border-color) !important;
            color: #ffffff !important;
            transition: all 0.3s ease;
        }
        .neo-input:focus {
            background-color: #0b0d10 !important;
            border-color: var(--neon-green) !important;
            box-shadow: 0 0 0 4px var(--neon-green-dim) !important;
        }
        /* Color del texto del placeholder al enfoque (floating labels de Bootstrap) */
        .neo-floating > label {
            color: var(--text-muted) !important;
            transition: all 0.2s ease-in-out;
        }
        .neo-floating > .neo-input:focus ~ label,
        .neo-floating > .neo-input:not(:placeholder-shown) ~ label {
            color: var(--neon-green) !important;
            background-color: transparent !important;
        }
        
        .neo-input::placeholder {
            color: transparent !important; /* Mantenemos transparente para que funcione el floating label */
        }
        /* Fix especial para los Selects y Opciones */
        select.neo-input option {
            background-color: var(--panel-bg);
            color: #ffffff;
        }

        /* Labels no flotantes y subtextos */
        .neo-label { color: var(--text-muted) !important; }
        .neo-label-file { color: #ffffff !important; }
        .neo-helper { color: var(--text-muted); font-size: 0.85rem; }
        .neo-input-file {
            background-color: var(--dark-bg) !important;
            border: 1px solid var(--border-color) !important;
            color: var(--text-muted) !important;
        }
        .neo-input-file::file-selector-button {
            background-color: var(--border-color);
            color: #fff;
            border: none;
            transition: 0.3s;
        }
        .neo-input-file::file-selector-button:hover {
            background-color: var(--neon-green);
            color: #000;
        }

        /* Botones Acción Inferior */
        .neo-btn-primary {
            background-color: var(--neon-green) !important;
            color: #000000 !important;
            border: none !important;
            transition: all 0.3s ease !important;
            box-shadow: 0 4px 15px var(--neon-green-dim) !important;
        }
        .neo-btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(0, 230, 118, 0.4) !important;
            background-color: #00ff84 !important;
        }

        .neo-btn-outline {
            color: var(--text-muted) !important;
            border: 1px solid var(--border-color) !important;
            background: transparent;
            transition: all 0.3s ease;
        }
        .neo-btn-outline:hover {
            color: #ffffff !important;
            border-color: #ffffff !important;
            background: rgba(255,255,255,0.05);
        }
        
        /* Ajustar Footer a modo oscuro si se muestra en esta pantalla */
        .footer {
            background-color: var(--dark-bg) !important;
            border-top: 1px solid var(--border-color) !important;
            color: var(--text-muted) !important;
        }
        .footer a {
            color: var(--neon-green) !important;
            text-decoration: none;
        }
    </style>
}

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Set current date time if empty
            var dateInput = document.querySelector('input[name="FechaCreacion"]');
            if(dateInput && !dateInput.value) {
                var now = new Date();
                now.setMinutes(now.getMinutes() - now.getTimezoneOffset());
                dateInput.value = now.toISOString().slice(0,16);
            }

            // Validar tamaño de imagen en Create
            var fotoInput = document.getElementById('FotoFileCreate');
            var fileInfo = document.getElementById('create-file-info');
            if (fotoInput) {
                fotoInput.addEventListener('change', function(e) {
                    if (e.target.files && e.target.files[0]) {
                        var file = e.target.files[0];
                        var maxSize = 10 * 1024 * 1024; // 10 MB
                        if (file.size > maxSize) {
                            alert('La imagen es demasiado grande. El tamaño máximo permitido es 10 MB.');
                            fotoInput.value = '';
                            fileInfo.textContent = 'Archivo rechazado: excede 10 MB';
                            fileInfo.style.color = '#ff3d00';
                        } else {
                            fileInfo.textContent = file.name + ' (' + (file.size / 1024 / 1024).toFixed(2) + ' MB)';
                            fileInfo.style.color = '#00e676';
                        }
                    } else {
                        fileInfo.textContent = '';
                    }
                });
            }
        });
    </script>
}
