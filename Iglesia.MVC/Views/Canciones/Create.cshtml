@model IglesiaGPS.modelo.Cancion

@{
    ViewData["Title"] = "Nueva Canción";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-header bg-success text-white text-center py-4 rounded-top-4">
                    <h2 class="mb-0 fw-bold"><i class="bi bi-music-note-list me-2"></i>Registrar Nueva Canción</h2>
                    <p class="mb-0 text-white-50">Ingresa los datos de la alabanza y opcionalmente sus notas musicales</p>
                </div>
                
                <div class="card-body p-5">
                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger shadow-sm"><i class="bi bi-exclamation-triangle-fill me-2"></i>@ViewBag.Error</div>
                    }

                    <form asp-action="Create" method="post" enctype="multipart/form-data">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <h5 class="text-success border-bottom pb-2 mb-4"><i class="bi bi-info-circle me-2"></i>Información Principal</h5>
                        
                        <div class="row g-4 mb-4">
                            <div class="col-md-6">
                                <div class="form-floating">
                                    <input asp-for="Titulo" class="form-control" placeholder="Título de la canción" required />
                                    <label asp-for="Titulo">Título <span class="text-danger">*</span></label>
                                    <span asp-validation-for="Titulo" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-floating">
                                    <input asp-for="Autor" class="form-control" placeholder="Autor o Interprete" required />
                                    <label asp-for="Autor">Autor / Artista <span class="text-danger">*</span></label>
                                    <span asp-validation-for="Autor" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-floating">
                                    <input asp-for="Tono" class="form-control" placeholder="Ej: Do Mayor, G, Am..." />
                                    <label asp-for="Tono">Tono</label>
                                    <span asp-validation-for="Tono" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-floating">
                                    <input asp-for="UrlAudio" class="form-control" type="text" placeholder="Enlace a YouTube o Audio" />
                                    <label asp-for="UrlAudio">Enlace a YouTube/Audio</label>
                                    <span asp-validation-for="UrlAudio" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-floating">
                                    <input asp-for="FechaCreacion" class="form-control" type="datetime-local" />
                                    <label asp-for="FechaCreacion">Fecha de Creación</label>
                                    <span asp-validation-for="FechaCreacion" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-floating">
                                    <select asp-for="CreadoPorUsuarioId" class="form-select" required>
                                        <option value="">-- Seleccione un Usuario --</option>
                                        @if(ViewBag.Usuarios != null)
                                        {
                                            foreach (var usuario in ViewBag.Usuarios)
                                            {
                                                <option value="@usuario.UsuarioId">@usuario.Nombre @usuario.Apellido</option>
                                            }
                                        }
                                    </select>
                                    <label asp-for="CreadoPorUsuarioId">Usuario Creador <span class="text-danger">*</span></label>
                                    <span asp-validation-for="CreadoPorUsuarioId" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="col-12">
                                <div class="form-floating">
                                    <textarea asp-for="Letra" class="form-control" placeholder="Letra de la canción" style="height: 120px"></textarea>
                                    <label asp-for="Letra">Letra (Exclusivo texto. ¡NO poner acordes aquí!)</label>
                                    <span asp-validation-for="Letra" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="col-12">
                                <div class="form-group mb-2">
                                    <label for="FotoFile" class="form-label fw-bold"><i class="bi bi-image me-2"></i>Foto del Artista / Banda (Opcional)</label>
                                    <input type="file" name="FotoFile" class="form-control form-control-lg bg-light" accept="image/*" />
                                    <small class="text-muted">Sube una imagen para identificar visualmente al autor de la alabanza.</small>
                                </div>
                            </div>
                        </div>

                        <h5 class="text-success border-bottom pb-2 mb-4 mt-5"><i class="bi bi-music-note me-2"></i>Notas Musicales (Opcional)</h5>
                        <p class="text-muted small">Agrega directamente la tablatura o acordes para esta canción.</p>

                        <div class="row g-4 mb-5 bg-light p-4 rounded-3 shadow-sm border">
                            <div class="col-md-4">
                                <div class="form-floating">
                                    <input type="text" name="Instrumento" class="form-control" placeholder="Ej: Guitarra, Piano, Bajo..." />
                                    <label for="Instrumento">Instrumento</label>
                                </div>
                            </div>
                            <div class="col-md-8">
                                <div class="form-floating">
                                    <textarea name="NotaContenido" class="form-control font-monospace" placeholder="Escribe aquí los acordes..." style="height: 150px"></textarea>
                                    <label for="NotaContenido">Acordes / Tablatura (¡Copia LAS NOTAS AQUÍ!)</label>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex justify-content-between align-items-center mt-4">
                            <a asp-action="Index" class="btn btn-outline-secondary btn-lg px-4 rounded-pill shadow-sm">
                                <i class="bi bi-arrow-left me-2"></i>Volver
                            </a>
                            <button type="submit" class="btn btn-success btn-lg px-5 rounded-pill shadow-sm fw-bold">
                                <i class="bi bi-save me-2"></i>Guardar Canción
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Set current date time if empty
            const dateInput = document.querySelector('input[name="FechaCreacion"]');
            if(dateInput && !dateInput.value) {
                const now = new Date();
                now.setMinutes(now.getMinutes() - now.getTimezoneOffset());
                dateInput.value = now.toISOString().slice(0,16);
            }
        });
    </script>
}
