@model IEnumerable<IglesiaGPS.modelo.Cancion>

@{
    ViewData["Title"] = "Canciones";
    var usuarioLogueado = Context.Session.GetString("UsuarioNombre");
    var usuarioRol = Context.Session.GetString("UsuarioRol");
    var recomendadas = ViewBag.Recomendadas as List<int> ?? new List<int>();
    var frecuencias = ViewBag.Frecuencias as Dictionary<int, int> ?? new Dictionary<int, int>();
    int maxFrecuencia = ViewBag.MaxFrecuencia != null ? (int)ViewBag.MaxFrecuencia : 1;
}

<div class="container mt-5">
    @* Un solo token antiforgery para JavaScript *@
    <form id="antiForgeryForm" class="d-none">
        @Html.AntiForgeryToken()
    </form>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="display-5 fw-bold mb-0" style="color: #ffffff; text-shadow: 0 0 15px rgba(0, 242, 254, 0.4);">Repertorio Musical</h1>
        @if (usuarioRol == "Director" || usuarioRol == "Desarrollador")
        {
            <a asp-action="Create" class="btn btn-lg shadow-sm" style="background: rgba(0, 242, 254, 0.1); border: 1px solid rgba(0, 242, 254, 0.4); color: #00f2fe; box-shadow: 0 0 15px rgba(0, 242, 254, 0.2);">
                <i class="bi bi-plus-circle me-2"></i>Nueva Canción
            </a>
        }
    </div>

    <!-- Barra de búsqueda Elegante Neón -->
    <div class="row mb-5 justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="search-box position-relative shadow-sm rounded-pill p-1 transition-hover" style="background: rgba(30, 41, 59, 0.7); border: 1px solid rgba(0, 242, 254, 0.3);">
                <div class="input-group input-group-lg border-0">
                    <span class="input-group-text bg-transparent border-0 ps-4 pe-2" style="color: #00f2fe;">
                        <i class="bi bi-search fs-4"></i>
                    </span>
                    <input type="text" id="searchInput" class="form-control bg-transparent border-0 shadow-none px-2 text-white" placeholder="Busca por título o artista..." aria-label="Buscar canciones">
                    <button class="btn rounded-pill px-4 fw-bold" type="button" onclick="document.getElementById('searchInput').focus()" style="background: linear-gradient(135deg, #0284c7, #0369a1); color: white; border: 1px solid rgba(0, 242, 254, 0.5);">Buscar</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Cuadrícula de Canciones -->
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 row-cols-xl-4 g-4" id="cancionesContainer">
        @foreach (var item in Model)
        {
            <div class="col cancion-card" data-autor="@item.Autor?.ToLower()" data-titulo="@item.Titulo?.ToLower()">
                <div class="card h-100 border-0 shadow-sm song-panel transition-hover" style="background: rgba(30, 41, 59, 0.6); backdrop-filter: blur(10px); border: 1px solid rgba(255, 255, 255, 0.05) !important;">
                    <div class="card-body d-flex flex-column text-center p-3">
                        
                        <!-- Contenedor del ícono/foto central (sirve de botón de selección en JS) -->
                        <div class="cancion-selector mx-auto mb-3 cancion-img-container position-relative" style="cursor: pointer;" >
                            @if (!string.IsNullOrEmpty(item.FotoUrl))
                            {
                                <img src="@item.FotoUrl" class="rounded-circle object-fit-cover shadow-sm cancion-foto" style="width: 70px; height: 70px; border: 2px solid rgba(0, 242, 254, 0.5);" alt="Foto de @item.Autor">
                            }
                            else
                            {
                                <div class="song-icon rounded-circle d-flex align-items-center justify-content-center shadow-sm mx-auto" style="width: 70px; height: 70px; background: rgba(0, 242, 254, 0.1); border: 1px solid rgba(0, 242, 254, 0.3); color: #00f2fe;">
                                    <i class="bi bi-music-note-beamed fs-3 icon-music"></i>
                                </div>
                            }
                            <!-- Etiqueta de orden de selección (Oculta por defecto) -->
                            <div class="seleccion-badge d-none position-absolute top-50 start-50 translate-middle text-white rounded-circle fw-bold fs-4 d-flex align-items-center justify-content-center shadow" style="width: 70px; height: 70px; z-index: 10; background-color: rgba(0, 242, 254, 0.85); border: 2px solid #fff;">
                                <span class="seleccion-numero text-dark">1</span>
                            </div>
                        </div>

                        <h5 class="card-title fw-bold text-truncate mb-1" title="@item.Titulo" style="font-size: 1.1rem; color: #ffffff;">@item.Titulo</h5>
                        <p class="card-text mb-2" style="font-size: 0.9rem; color: #94a3b8;">
                            <i class="bi bi-person-fill"></i> @(string.IsNullOrEmpty(item.Autor) ? "Desconocido" : item.Autor)
                        </p>
                        
                        @{
                            int frec = frecuencias.ContainsKey(item.CancionId) ? frecuencias[item.CancionId] : 0;
                            double porcentaje = maxFrecuencia > 0 ? ((double)frec / maxFrecuencia) * 100 : 0;
                            string colorBarra = "#0ea5e9"; // Azul por defecto (poco uso)
                            if (porcentaje > 75) colorBarra = "#ef4444"; // Rojo (muy usado)
                            else if (porcentaje > 40) colorBarra = "#eab308"; // Amarillo (uso medio)
                        }
                        
                        <!-- Barra de Frecuencia de Uso (Últimos 3 meses) -->
                        <div class="mb-3 text-start w-100" title="Uso últimos 3 meses: @frec veces">
                            <div class="d-flex justify-content-between align-items-center mb-1">
                                <span style="font-size: 0.75rem; color: #64748b;"><i class="bi bi-bar-chart-fill"></i> Frecuencia (3 meses)</span>
                                <span style="font-size: 0.75rem; color: #94a3b8; font-weight: bold;">@frec @(frec == 1 ? "vez" : "veces")</span>
                            </div>
                            <div class="progress" style="height: 6px; background-color: rgba(255,255,255,0.1); border-radius: 3px; overflow: hidden;">
                                <div class="progress-bar" role="progressbar" style="width: @porcentaje%; background-color: @colorBarra; transition: width 1s ease-in-out;" aria-valuenow="@porcentaje" aria-valuemin="0" aria-valuemax="100"></div>
                            </div>
                        </div>
                        
                        <div class="mt-auto">
                            <!-- Botón Tono y Eliminar Pequeño -->
                            <div class="mb-2 d-flex justify-content-between align-items-center">
                                <span class="badge rounded-pill px-3 py-2 fw-semibold shadow-sm" style="font-size: 0.85rem; background: rgba(0, 242, 254, 0.1); color: #00f2fe; border: 1px solid rgba(0, 242, 254, 0.3);">
                                    Tono: @(string.IsNullOrEmpty(item.Tono) ? "-" : item.Tono)
                                </span>
                                @if (usuarioRol == "Director" || usuarioRol == "Desarrollador")
                                {
                                    <form asp-action="DeleteConfirmed" method="post" class="d-inline mb-0" onsubmit="return confirm('¿Eliminar la canción \'@item.Titulo\' permanentemente?');">
                                        <input type="hidden" name="id" value="@item.CancionId" />
                                        <button type="submit" class="btn btn-sm text-danger p-0 m-0 border-0 bg-transparent" title="Eliminar Canción">
                                            <i class="bi bi-trash fs-6" style="opacity: 0.7; transition: opacity 0.2s; filter: drop-shadow(0 0 2px rgba(2ef,68,68,0.5));" onmouseover="this.style.opacity='1'" onmouseout="this.style.opacity='0.7'"></i>
                                        </button>
                                    </form>
                                }
                            </div>
                            
                            <!-- Botones Principales -->
                            <div class="d-grid gap-2">
                                <button class="btn btn-sm btn-ver-notas rounded-pill fw-semibold shadow-sm py-2 text-white" data-id="@item.CancionId" data-titulo="@item.Titulo" style="background: linear-gradient(135deg, #0d9488, #0f766e); border: 1px solid rgba(255,255,255,0.1);">
                                    <i class="bi bi-journal-text me-1"></i> Ver Notas
                                </button>
                                
                                <div class="btn-group w-100 mt-1 shadow-sm rounded-pill overflow-hidden" role="group">
                                    @if (usuarioLogueado != null)
                                    {
                                        <!-- Boton de Recomendación Cyberpunk -->
                                        @if (usuarioRol != "Director")
                                        {
                                            @if (recomendadas.Contains(item.CancionId))
                                            {
                                                <button class="btn btn-sm py-2 px-3 fw-bold flex-grow-1" disabled style="background: rgba(29, 233, 182, 0.1); border: 1px solid var(--cyber-teal); color: var(--cyber-teal); box-shadow: 0 0 10px rgba(29,233,182,0.3);">
                                                    <i class="bi bi-star-fill"></i> Recomendada
                                                </button>
                                            }
                                            else
                                            {
                                                <button class="btn btn-sm py-2 px-3 fw-bold flex-grow-1 btn-recomendar" data-cancion-id="@item.CancionId" style="background: rgba(255, 61, 0, 0.1); border: 1px solid rgba(255, 61, 0, 0.5); color: #ff3d00; transition: all 0.3s ease;">
                                                    <i class="bi bi-star"></i> Recomendar
                                                </button>
                                            }
                                        }

                                        @if (usuarioRol == "Director" || usuarioRol == "Desarrollador")
                                        {
                                            <a asp-action="Edit" asp-route-id="@item.CancionId" class="btn btn-sm py-2 px-3 text-white" style="background: #1e293b; border: 1px solid rgba(255,255,255,0.1); border-left: 1px solid rgba(255,255,255,0.05); border-right: 1px solid rgba(255,255,255,0.05);" title="Editar Canción">
                                                <i class="bi bi-pencil" style="font-size: 0.8rem;"></i>
                                            </a>
                                        }
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<!-- Modal para Notas Musicales Cyberpunk -->
<div class="modal fade" id="notasModal" tabindex="-1" aria-labelledby="notasModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg modal-dialog-scrollable">
        <div class="modal-content border-0 shadow-lg" style="background: #0f172a; border: 1px solid rgba(0, 242, 254, 0.4) !important; border-radius: 12px; overflow: hidden;">
            <div class="modal-header" style="background: linear-gradient(90deg, #0f172a, #1e293b); border-bottom: 2px solid rgba(0, 242, 254, 0.3);">
                <h5 class="modal-title fw-bold" id="notasModalLabel" style="color: #00f2fe; text-shadow: 0 0 10px rgba(0, 242, 254, 0.4);">
                    <i class="bi bi-music-note-list me-2"></i>Notas Musicales
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close" style="opacity: 0.8; filter: drop-shadow(0 0 5px rgba(0,242,254,0.5));"></button>
            </div>
            <div class="modal-body" id="notasModalBody" style="background: #0f172a; color: #e2e8f0; padding: 2rem 1.5rem;">
                <div class="text-center py-5">
                    <div class="spinner-border text-info" role="status" style="width: 3rem; height: 3rem;">
                        <span class="visually-hidden">Cargando...</span>
                    </div>
                    <p class="mt-3" style="color: #00f2fe; letter-spacing: 1px;">Sincronizando notas desde el servidor principal...</p>
                </div>
            </div>
            <div class="modal-footer border-0" style="background: #0f172a; border-top: 1px solid rgba(0, 242, 254, 0.2) !important;">
                <button type="button" class="btn text-white fw-bold px-4" data-bs-dismiss="modal" style="background: #334155; border: 1px solid #475569; transition: 0.3s;" onmouseover="this.style.background='#475569'" onmouseout="this.style.background='#334155'">
                    Cerrar Enlace
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Panel Flotante de Selección (Solo para Director/Desarrollador) -->
@if (usuarioRol == "Director" || usuarioRol == "Desarrollador")
{
    <div id="panelSeleccion" class="position-fixed bottom-0 start-50 translate-middle-x p-3 mb-4 rounded-pill shadow-lg d-none align-items-center" style="z-index: 1050; min-width: 350px; background: rgba(15, 23, 42, 0.95); backdrop-filter: blur(10px); border: 2px solid rgba(0, 242, 254, 0.4); box-shadow: 0 0 20px rgba(0, 242, 254, 0.15) !important;">
        <div class="me-auto d-flex align-items-center">
            <div class="text-white rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 44px; height: 44px; background: rgba(0, 242, 254, 0.2); border: 2px solid #00f2fe; color: #00f2fe;">
                <span id="contadorSeleccionadas" class="fw-bold fs-5" style="text-shadow: 0 0 5px rgba(0, 242, 254, 0.5);">0</span>
            </div>
            <span class="fw-bold text-white fs-5">Canciones<br><small class="fw-normal" style="font-size:0.75rem; color: #94a3b8;">(Mín 5, Máx 7)</small></span>
        </div>
        <button id="btnGuardarLista" class="btn text-dark rounded-pill fw-bold px-4 ms-3" disabled style="background: #00f2fe; box-shadow: 0 0 15px rgba(0, 242, 254, 0.4); border: none;">
            <i class="bi bi-save me-1"></i> Guardar Lista
        </button>
    </div>
}

@section Styles {
    <style>
        /* Fondo oscuro exclusivo para Index Canciones */
        body { 
            background-color: #0b1120 !important; 
            color: #e2e8f0 !important;
        }
        main { 
            background-color: transparent !important; 
        }
        /* Ajuste de Placeholder búsqueda oscura */
        #searchInput::placeholder {
            color: rgba(255, 255, 255, 0.4);
        }
        #searchInput:focus {
            color: #ffffff;
        }
        /* Estilar panel y transiciones Hover con destello */
        .song-panel {
            border-radius: 15px;
            overflow: hidden;
            border-left: 5px solid #00f2fe !important;
            transition: all 0.3s ease;
        }
        .transition-hover:hover {
            transform: translateY(-8px);
            box-shadow: 0 10px 25px rgba(0, 242, 254, 0.15) !important;
            border-color: rgba(0, 242, 254, 0.4) !important;
            background: rgba(30, 41, 59, 0.9) !important;
        }
        .song-icon {
            box-shadow: inset 0 2px 4px rgba(0,0,0,0.2);
        }
        .btn-ver-notas:hover {
            background: linear-gradient(135deg, #14b8a6, #0f766e) !important;
            box-shadow: 0 0 10px rgba(255, 255, 255, 0.15);
        }
        /* Ajustar Footer a modo oscuro para que encaje */
        .footer {
            background-color: #0b1120 !important;
            border-top: 1px solid rgba(0, 242, 254, 0.2) !important;
            color: #475569 !important;
            box-shadow: 0 -10px 30px rgba(0, 242, 254, 0.05);
        }
        .footer a {
            color: #00f2fe !important;
            text-decoration: none;
            transition: 0.3s;
        }
        .footer a:hover {
            text-shadow: 0 0 10px rgba(0, 242, 254, 0.6);
            color: #ffffff !important;
        }
    </style>
}

@section Scripts {
    <script src="~/js/canciones-index.js" asp-append-version="true"></script>
}
