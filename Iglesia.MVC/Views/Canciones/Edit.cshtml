@model IglesiaGPS.modelo.Cancion

@{
    ViewData["Title"] = "Editar Canción";
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-header bg-primary text-white text-center py-4 rounded-top-4">
                    <h2 class="mb-0 fw-bold"><i class="bi bi-pencil-square me-2"></i>Editar Canción</h2>
                    <p class="mb-0 text-white-50">Modifica los detalles de la alabanza y actualiza sus notas musicales</p>
                </div>
                
                <div class="card-body p-5">
                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger shadow-sm"><i class="bi bi-exclamation-triangle-fill me-2"></i>@ViewBag.Error</div>
                    }

                    <form asp-action="Edit" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                        <input type="hidden" asp-for="CancionId" />

                        <h5 class="text-primary border-bottom pb-2 mb-4"><i class="bi bi-info-circle me-2"></i>Información Principal</h5>
                        
                        <div class="row g-4 mb-4">
                            <div class="col-md-6">
                                <div class="form-floating">
                                    <input asp-for="Titulo" class="form-control" placeholder="Título de la canción" required />
                                    <label asp-for="Titulo">Título <span class="text-danger">*</span></label>
                                    <span asp-validation-for="Titulo" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-floating">
                                    <input asp-for="Autor" class="form-control" placeholder="Autor o Interprete" required />
                                    <label asp-for="Autor">Autor / Artista <span class="text-danger">*</span></label>
                                    <span asp-validation-for="Autor" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-floating">
                                    <input asp-for="Tono" class="form-control" placeholder="Ej: Do Mayor, G, Am..." />
                                    <label asp-for="Tono">Tono</label>
                                    <span asp-validation-for="Tono" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-floating">
                                    <input asp-for="UrlAudio" class="form-control" type="text" placeholder="Enlace a YouTube o Audio" />
                                    <label asp-for="UrlAudio">Enlace a YouTube/Audio</label>
                                    <span asp-validation-for="UrlAudio" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-floating">
                                    <input asp-for="FechaCreacion" class="form-control" type="datetime-local" />
                                    <label asp-for="FechaCreacion">Fecha de Creación</label>
                                    <span asp-validation-for="FechaCreacion" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-floating">
                                    <select asp-for="CreadoPorUsuarioId" class="form-select" required>
                                        <option value="">-- Seleccione un Usuario --</option>
                                        @if(ViewBag.Usuarios != null)
                                        {
                                            foreach (var usuario in ViewBag.Usuarios)
                                            {
                                                <option value="@usuario.UsuarioId">@usuario.Nombre @usuario.Apellido</option>
                                            }
                                        }
                                    </select>
                                    <label asp-for="CreadoPorUsuarioId">Usuario Creador <span class="text-danger">*</span></label>
                                    <span asp-validation-for="CreadoPorUsuarioId" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="col-12">
                                <div class="form-floating">
                                    <textarea asp-for="Letra" class="form-control" placeholder="Letra de la canción" style="height: 120px"></textarea>
                                    <label asp-for="Letra">Letra</label>
                                    <span asp-validation-for="Letra" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>

                        <h5 class="text-primary border-bottom pb-2 mb-4 mt-5"><i class="bi bi-music-note-list me-2"></i>Notas Musicales Existentes</h5>
                        
                        @if (Model.NotasMusicales != null && Model.NotasMusicales.Any())
                        {
                            <div class="row g-4 mb-4">
                                @foreach (var nota in Model.NotasMusicales)
                                {
                                    <div class="col-12">
                                        <div class="p-3 bg-light rounded shadow-sm border">
                                            <input type="hidden" name="NotaIds" value="@nota.NotaMusicalId" />
                                            <div class="d-flex justify-content-between align-items-center mb-2">
                                                <span class="badge bg-secondary">Instrumento: @nota.Instrumento</span>
                                                <small class="text-muted">Última edición: @nota.UltimaEdicion.ToShortDateString()</small>
                                            </div>
                                            <textarea name="NotaContenidos" class="form-control font-monospace" style="height: 100px">@nota.Contenido</textarea>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-info shadow-sm">
                                <i class="bi bi-info-circle-fill me-2"></i>Esta canción aún no tiene notas registradas. Puedes agregar una a continuación.
                            </div>
                        }

                        <h5 class="text-success border-bottom pb-2 mb-4 mt-4"><i class="bi bi-plus-circle me-2"></i>Agregar Nueva Nota (Opcional)</h5>
                        <div class="row g-4 mb-5 bg-light p-4 rounded-3 shadow-sm border border-success-subtle">
                            <div class="col-md-4">
                                <div class="form-floating">
                                    <input type="text" name="NewInstrumento" class="form-control" placeholder="Ej: Batería, Voz..." />
                                    <label for="NewInstrumento">Instrumento</label>
                                </div>
                            </div>
                            <div class="col-md-8">
                                <div class="form-floating">
                                    <textarea name="NewNotaContenido" class="form-control font-monospace" placeholder="Escribe aquí los acordes o tablatura..." style="height: 100px"></textarea>
                                    <label for="NewNotaContenido">Acordes / Tablatura nueva</label>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex justify-content-between align-items-center mt-4">
                            <a asp-action="Index" class="btn btn-outline-secondary btn-lg px-4 rounded-pill shadow-sm">
                                <i class="bi bi-arrow-left me-2"></i>Cancelar
                            </a>
                            <button type="submit" class="btn btn-primary btn-lg px-5 rounded-pill shadow-sm fw-bold">
                                <i class="bi bi-save me-2"></i>Actualizar Cambios
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
