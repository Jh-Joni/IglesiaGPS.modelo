@{
    ViewData["Title"] = "Iniciar Sesión";
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Iniciar Sesión – Iglesia GPS</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://fonts.googleapis.com/css2?family=Raleway:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="icon" type="image/png" href="~/imagen/logosinfondo.png" />
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Raleway', sans-serif;
            background-color: #2d3250;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #ffffff;
            padding: 20px;
        }

        .auth-container {
            display: flex;
            width: 100%;
            max-width: 900px;
            height: 550px;
            background: #424769;
            border-radius: 20px;
            overflow: hidden;
            box-shadow: 0 30px 60px rgba(0, 0, 0, 0.4);
            animation: fadeIn 0.8s ease-out;
        }

        @@keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* ----- PANEL IZQUIERDO (Formulario) ----- */
        .auth-panel-form {
            flex: 1;
            padding: 50px 60px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            position: relative;
        }

        .auth-tabs {
            margin-bottom: 40px;
            display: flex;
            gap: 20px;
        }

        .auth-tabs a {
            text-decoration: none;
            color: #676f9d;
            font-size: 14px;
            font-weight: 600;
            padding-bottom: 5px;
            transition: 0.3s;
        }

        .auth-tabs a.active {
            color: #ffffff;
            border-bottom: 2px solid #f9b17a;
        }

        .auth-tabs a:hover:not(.active) {
            color: #ffffff;
        }

        .auth-titles h1 {
            font-size: 32px;
            font-weight: 700;
            margin-bottom: 5px;
        }

        .auth-titles p {
            font-size: 13px;
            color: #ffffff;
            opacity: 0.8;
            margin-bottom: 35px;
        }

        .form-group {
            margin-bottom: 25px;
            position: relative;
        }

        .form-group label {
            position: absolute;
            top: 10px;
            left: 15px;
            font-size: 10px;
            color: #676f9d;
            text-transform: uppercase;
            font-weight: 600;
            letter-spacing: 0.5px;
            pointer-events: none;
        }

        .form-group input {
            width: 100%;
            background: #53587d;
            border: 1px solid transparent;
            border-radius: 8px;
            padding: 25px 15px 10px 15px;
            color: #ffffff;
            font-family: 'Raleway', sans-serif;
            font-size: 14px;
            font-weight: 600;
            outline: none;
            transition: 0.3s;
        }

        .form-group input::placeholder {
            color: #8c93bc;
        }

        .form-group input:focus {
            border-color: #676f9d;
            background: #5b6088;
        }

        .auth-options {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px;
        }

        .auth-options label {
            font-size: 12px;
            color: #ffffff;
            opacity: 0.8;
            display: flex;
            align-items: center;
            gap: 8px;
            cursor: pointer;
        }

        .auth-options a {
            font-size: 12px;
            color: #676f9d;
            text-decoration: none;
            transition: 0.3s;
        }

        .auth-options a:hover {
            color: #f9b17a;
        }

        .btn-submit {
            background: #f9b17a;
            color: #2d3250;
            border: none;
            padding: 14px 40px;
            border-radius: 8px;
            font-family: 'Raleway', sans-serif;
            font-size: 14px;
            font-weight: 700;
            cursor: pointer;
            transition: 0.3s;
            display: block;
        }

        .btn-submit:hover {
            background: #ffc99e;
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(249, 177, 122, 0.2);
        }

        /* Ocultar el scroll del navegador si la pantalla es muy pequeña */
        @@media (max-width: 768px) {
            .auth-panel-image { display: none; }
            .auth-container { max-width: 450px; }
            .auth-panel-form { padding: 40px; }
        }

        /* ----- PANEL DERECHO (Imagen) ----- */
        .auth-panel-image {
            flex: 1;
            /* Reemplazar la URL por una imagen propia de montañas, o un gradiente estético si no hay imagen externa. Usado de Unsplash de referencia. */
            background: url('https://images.unsplash.com/photo-1464822759023-fed622ff2c3b?q=80&w=1470&auto=format&fit=crop') center center / cover no-repeat;
            position: relative;
        }

        .auth-panel-image::before {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(to left, rgba(66, 71, 105, 0.1), rgba(66, 71, 105, 0.8));
        }

        /* Alertas */
        .alert-error {
            background: rgba(200, 50, 50, 0.2);
            border-left: 3px solid #ff6b6b;
            color: #ffcccc;
            padding: 10px 15px;
            font-size: 12px;
            margin-bottom: 20px;
            border-radius: 0 4px 4px 0;
        }

        .alert-success {
            background: rgba(50, 200, 100, 0.2);
            border-left: 3px solid #6bff95;
            color: #ccffcc;
            padding: 10px 15px;
            font-size: 12px;
            margin-bottom: 20px;
            border-radius: 0 4px 4px 0;
        }
    </style>
</head>
<body>

    <!-- Logo superior minimalista -->
    <div style="position: absolute; top: 30px; left: 40px; color: #676f9d; font-size: 12px; font-weight: 700; letter-spacing: 1px;">
        <img src="~/imagen/logosinfondo.png" alt="Logo" style="height: 20px; vertical-align: middle; margin-right: 8px; filter: grayscale(1) brightness(1.5);"> MINISTERIO DE ALABANZA
    </div>
    <div style="position: absolute; top: 30px; right: 40px; color: #676f9d; font-size: 12px; font-weight: 700; letter-spacing: 1px;">
        UX | UI DESIGN ♦ IGLESIA GPS
    </div>

    <div class="auth-container">
        <!-- Panel del Formulario -->
        <div class="auth-panel-form">
            <div class="auth-tabs">
                <a href="@Url.Action("Login", "Auth")" class="active">Ingresar</a>
                <a href="@Url.Action("Registro", "Auth")">Registro</a>
            </div>

            <div class="auth-titles">
                <h1>¡Te extrañamos!</h1>
                <p>Inicia sesión para continuar</p>
            </div>

            @if (ViewBag.Error != null)
            {
                <div class="alert-error">@ViewBag.Error</div>
            }

            @if (TempData["Exito"] != null)
            {
                <div class="alert-success">@TempData["Exito"]</div>
            }

            <form method="post" asp-action="Login" asp-controller="Auth">
                @Html.AntiForgeryToken()

                <div class="form-group">
                    <label>Correo</label>
                    <input type="email" id="correo" name="correo" placeholder="alguien@ejemplo.com" required autocomplete="email" />
                </div>

                <div class="form-group">
                    <label>Contraseña</label>
                    <input type="password" id="contrasena" name="contrasena" placeholder="••••••••" required autocomplete="current-password" />
                </div>

                <div class="auth-options">
                    <label>
                        <input type="checkbox" id="chkRecordarme" style="width: auto; appearance: none; width: 14px; height: 14px; border: 1px solid #676f9d; border-radius: 3px; background: transparent; cursor: pointer; position: relative;" 
                               onchange="this.style.background = this.checked ? '#f9b17a' : 'transparent'"> Recordarme
                    </label>
                    <a href="@Url.Action("RecuperarContrasena", "Auth")">¿Olvidaste la clave?</a>
                </div>

                <div style="display: flex; gap: 20px; align-items: center;">
                    <button type="submit" class="btn-submit">Ingresar</button>
                    <!-- Puedes poner accesos a redes aquí si lo deseas en un futuro -->
                </div>
            </form>
        </div>

        <!-- Panel de la Imagen de Fondo -->
        <div class="auth-panel-image"></div>
    </div>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const correoInput = document.getElementById("correo");
            const chkRecordarme = document.getElementById("chkRecordarme");
            const savedCorreo = localStorage.getItem("gps_saved_email");

            if (savedCorreo) {
                correoInput.value = savedCorreo;
                chkRecordarme.checked = true;
                chkRecordarme.style.background = '#f9b17a';
            }

            document.querySelector("form").addEventListener("submit", function () {
                if (chkRecordarme.checked) {
                    localStorage.setItem("gps_saved_email", correoInput.value);
                } else {
                    localStorage.removeItem("gps_saved_email");
                }
            });
        });
    </script>
</body>
</html>
