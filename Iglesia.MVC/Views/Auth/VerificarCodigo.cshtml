@{
    ViewData["Title"] = "Verificar Código";
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Verificar Código – Iglesia GPS</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Poppins', sans-serif;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, #0a1f44 0%, #1a3a6c 50%, #0a1f44 100%);
            position: relative;
            overflow: hidden;
        }

        body::before {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle at 40% 60%, rgba(212, 175, 55, 0.08) 0%, transparent 50%),
                        radial-gradient(circle at 80% 20%, rgba(212, 175, 55, 0.05) 0%, transparent 50%);
            animation: float 15s ease-in-out infinite;
        }

        @@keyframes float {
            0%, 100% { transform: translate(0, 0) rotate(0deg); }
            33% { transform: translate(30px, -30px) rotate(1deg); }
            66% { transform: translate(-20px, 20px) rotate(-1deg); }
        }

        .auth-container {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(20px);
            border-radius: 20px;
            padding: 50px 40px;
            width: 100%;
            max-width: 440px;
            box-shadow: 0 25px 60px rgba(0, 0, 0, 0.3);
            position: relative;
            z-index: 1;
            animation: slideUp 0.6s ease-out;
        }

        @@keyframes slideUp {
            from { opacity: 0; transform: translateY(30px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .auth-logo {
            text-align: center;
            margin-bottom: 25px;
        }

        .auth-logo .icon {
            font-size: 48px;
            display: block;
            margin-bottom: 10px;
        }

        .auth-logo h1 {
            color: #0a1f44;
            font-size: 24px;
            font-weight: 700;
        }

        .auth-logo p {
            color: #888;
            font-size: 14px;
            margin-top: 5px;
        }

        .form-group {
            margin-bottom: 22px;
        }

        .form-group label {
            display: block;
            color: #0a1f44;
            font-weight: 500;
            font-size: 14px;
            margin-bottom: 8px;
        }

        .form-group input {
            width: 100%;
            padding: 14px 18px;
            border: 2px solid #e0e0e0;
            border-radius: 12px;
            font-family: 'Poppins', sans-serif;
            font-size: 14px;
            transition: all 0.3s ease;
            outline: none;
            background: #fafafa;
        }

        .form-group input:focus {
            border-color: #d4af37;
            background: white;
            box-shadow: 0 0 0 4px rgba(212, 175, 55, 0.1);
        }

        .code-input {
            text-align: center;
            font-size: 28px !important;
            font-weight: 700;
            letter-spacing: 12px;
            color: #0a1f44;
        }

        .btn-primary-auth {
            width: 100%;
            padding: 14px;
            background: linear-gradient(135deg, #0a1f44, #1a3a6c);
            color: white;
            border: none;
            border-radius: 12px;
            font-family: 'Poppins', sans-serif;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            margin-top: 10px;
        }

        .btn-primary-auth:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(10, 31, 68, 0.3);
        }

        .btn-primary-auth:active {
            transform: translateY(0);
        }

        .alert-error {
            background: #fff0f0;
            border: 1px solid #ffcdd2;
            color: #c62828;
            padding: 12px 16px;
            border-radius: 10px;
            font-size: 13px;
            margin-bottom: 20px;
            animation: shake 0.4s ease-out;
        }

        .alert-success {
            background: #f0fff4;
            border: 1px solid #c8e6c9;
            color: #2e7d32;
            padding: 12px 16px;
            border-radius: 10px;
            font-size: 13px;
            margin-bottom: 20px;
        }

        .alert-info {
            background: #f0f4ff;
            border: 1px solid #d0d8f0;
            color: #0a1f44;
            padding: 12px 16px;
            border-radius: 10px;
            font-size: 13px;
            margin-bottom: 20px;
            text-align: center;
        }

        @@keyframes shake {
            0%, 100% { transform: translateX(0); }
            25% { transform: translateX(-5px); }
            75% { transform: translateX(5px); }
        }

        .email-display {
            text-align: center;
            margin-bottom: 20px;
        }

        .email-display span {
            background: #f4f6f9;
            padding: 8px 20px;
            border-radius: 20px;
            font-size: 13px;
            color: #0a1f44;
            font-weight: 500;
        }

        .auth-footer {
            text-align: center;
            margin-top: 20px;
            color: #888;
            font-size: 14px;
        }

        .auth-footer a {
            color: #d4af37;
            text-decoration: none;
            font-weight: 600;
            transition: 0.3s;
        }

        .auth-footer a:hover {
            color: #b8942e;
            text-decoration: underline;
        }
    </style>
</head>
<body>
    <div class="auth-container">
        <div class="auth-logo">
            <span class="icon">📧</span>
            <h1>Verificar Correo</h1>
            <p>Ingresa el código de 6 dígitos</p>
        </div>

        @if (ViewBag.Error != null)
        {
            <div class="alert-error">⚠️ @ViewBag.Error</div>
        }

        @if (ViewBag.Mensaje != null && !string.IsNullOrEmpty(ViewBag.Mensaje.ToString()))
        {
            <div class="alert-success">✅ @ViewBag.Mensaje</div>
        }

        <div class="alert-info">
            📬 Revisa tu bandeja de entrada y la carpeta de spam
        </div>

        <form method="post" asp-action="VerificarCodigo" asp-controller="Auth">
            @Html.AntiForgeryToken()

            <input type="hidden" id="correo" name="correo" value="@ViewBag.Correo" />

            @if (!string.IsNullOrEmpty(ViewBag.Correo?.ToString()))
            {
                <div class="email-display">
                    <span>📧 @ViewBag.Correo</span>
                </div>
            }

            <div class="form-group">
                <label for="codigo">Código de Verificación</label>
                <input type="text" id="codigo" name="codigo" class="code-input"
                       placeholder="000000" maxlength="6" pattern="[0-9]{6}"
                       required autocomplete="off" />
            </div>

            <button type="submit" class="btn-primary-auth">Verificar Cuenta</button>
        </form>

        <div class="auth-footer">
            <a href="@Url.Action("Login", "Auth")">← Volver a Iniciar Sesión</a>
        </div>
    </div>
</body>
</html>
