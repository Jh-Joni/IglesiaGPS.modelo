@model IglesiaGPS.modelo.SolicitudDirector
@{
    ViewData["Title"] = "Solicitud para Director de Alabanza";
    var usuarioRol = Context.Session.GetString("UsuarioRol");
}

<div class="container mt-5 mb-5 d-flex justify-content-center">
    <div class="card shadow border-0" style="border-radius: 15px; max-width: 600px; width: 100%;">
        <div class="card-header bg-primary text-white text-center py-4" style="border-radius: 15px 15px 0 0;">
            <h2 class="mb-0 fw-bold"><i class="bi bi-star-fill me-2 text-warning"></i>Únete como Director</h2>
        </div>
        
        <div class="card-body p-5 text-center bg-light">
            
            @if (usuarioRol == "Director")
            {
                <div class="alert alert-success d-flex align-items-center mb-0" role="alert">
                    <i class="bi bi-check-circle-fill fs-3 me-3"></i>
                    <div>
                        <h5 class="alert-heading mb-1 fw-bold">¡Felicidades! Ya eres Director</h5>
                        <p class="mb-0">Ahora tienes acceso para crear listas de canciones de la semana y editar el repertorio con herramientas exclusivas.</p>
                    </div>
                </div>
            }
            else
            {
                <h4 class="text-dark mb-4 fw-bold">¿Deseas guiar la adoración?</h4>
                <p class="text-secondary mb-4" style="font-size: 1.1rem;">
                    Como <strong>Director de Alabanza</strong> tendrás opciones extras en nuestra plataforma. Podrás dar la bienvenida a las listas, armar el repertorio semanal (canciones a tocar) y actualizar los tonos y notas para tu equipo.
                </p>

                <div class="p-3 bg-white rounded shadow-sm border mb-4 text-start">
                    <h6 class="fw-bold text-primary mb-3"><i class="bi bi-gift-fill me-2"></i>Beneficios del Rol:</h6>
                    <ul class="text-muted mb-0">
                        <li><i class="bi bi-check2 text-success me-2"></i>Crear listas de canciones para los domingos.</li>
                        <li><i class="bi bi-check2 text-success me-2"></i>Publicar Mensajes o Versículos en el Inicio.</li>
                        <li><i class="bi bi-check2 text-success me-2"></i>Añadir completamente nuevas canciones al repertorio.</li>
                    </ul>
                </div>

                @if (Model != null && Model.Estado == "Pendiente")
                {
                    <div class="alert alert-warning d-flex align-items-center justify-content-center fw-bold" role="alert" style="font-size: 1.1rem; border-left: 5px solid #ffc107;">
                        <i class="bi bi-hourglass-split fs-4 me-3"></i>
                        <span>Espera a que el desarrollador te acepte.</span>
                    </div>
                }
                else
                {
                    <form asp-action="Solicitar" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-success btn-lg w-100 rounded-pill fw-bold shadow-sm" style="background-color: #2e7d32; border:none; padding:15px;">
                            <i class="bi bi-send-fill me-2"></i> Solicitar Ser Director
                        </button>
                    </form>
                }
            }

        </div>
    </div>
</div>
